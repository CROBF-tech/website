---
// Carrusel 3D con efecto de rotación - Diseño 3D azul violeta negro
const items = [
	{ type: 'video' as const, src: '/video_1.mp4' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%201.png' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%202.png' },
	{ type: 'video' as const, src: '/video_3.mp4' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%203.png' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%204.png' },
	{ type: 'video' as const, src: '/video_4.mp4' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%205.png' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%206.png' },
	{ type: 'video' as const, src: '/video_5.mp4' },
	{ type: 'image' as const, src: '/images/Imagen%20Carrusel%207.png' },
];

const totalCards = items.length;
---

<div class="carousel-wrapper">
	<section class="carousel-section">
		<div class="scene">
			<div class="a3d" style={`--n: ${totalCards}`}>
				{items.map((item, index) => (
					item.type === 'video' ? (
						<video 
							class="card" 
							src={item.src}
							style={`--i: ${index}`}
							autoplay
							muted
							loop
							playsinline
						/>
					) : (
						<img 
							class="card" 
							src={item.src}
							style={`--i: ${index}`} 
							alt="Web development workspace"
							loading="lazy"
						/>
					)
				))}
			</div>
		</div>
	</section>
</div>

<style>
	.carousel-wrapper {
		/*
		 * El wrapper TAMBIÉN rompe a full-width con el mismo truco 100vw.
		 * Así en desktop no recorta nada (es tan ancho como el viewport).
		 * En mobile/tablet, overflow-x:clip evita scroll horizontal
		 * sin romper el 3D (a diferencia de overflow:hidden).
		 */
		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		position: relative;
	}

	.carousel-section {
		width: 100%;
		/* mover carrusel hacia arriba para integrarlo con la hero-intro */
		padding: 1rem 0 12rem;
		/* aumentar margin-top negativo para elevar el carrusel sobre la hero */
		margin-top: -16rem;
		margin-bottom: 4rem;
		display: grid;
		place-items: center;
		/* Permitir que las cards se vean completamente */
		overflow: visible !important;
		/* Eliminar cualquier clipping */
		clip-path: none;
		position: relative;
		/* Forzar que no se corte */
		contain: none;
		/* Z-index MUY alto para estar por encima de TODO excepto el nav */
		z-index: 999;
		/* Asegurar que nada corte el contenido */
		isolation: isolate;
	}

	/* ====== Relevant CSS ====== */
	.scene, 
	.a3d {
		display: grid;
	}

	.scene {
		/* NO usar overflow hidden aquí para evitar clipping */
		overflow: visible !important;
		/* for 3D look; smaller = more extreme effect */
		perspective: 35em;
		min-height: 900px;
		width: 100%;
		display: grid;
		place-items: center;
		/* Agregar padding vertical MUY generoso para que las cards NUNCA se corten */
		padding: 8rem 0;
		/* Eliminar cualquier clipping */
		clip-path: none;
		position: relative;
		/* Forzar que no se corte */
		contain: none;
		/* Z-index para estar por encima */
		z-index: 100;
	}

	.a3d {
		place-self: center /* middle align */;
		/* don't flatten 3D transformed children 
		 * of this parent having its own 3D transform */
		transform-style: preserve-3d;
		animation: ry 32s linear infinite;
		/* Mejorar rendimiento durante scroll */
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		/* Asegurar que no haya clipping */
		overflow: visible;
		/* Z-index para las cards */
		position: relative;
		z-index: 101;
	}

	/* simplest y axis rotation */
	@keyframes ry {
		to {
			rotate: y 1turn;
		}
	}

	.card {
		/* Desktop card size: 400x571 */
		--w: 400px;

		/* compute base angle corresponding to a card */
		--ba: 1turn/var(--n); /* in the future: sibling-count() */
		
		grid-area: 1/ 1 /* stack in same one grid cell */;
		width: var(--w);
		max-width: 90vw;
		aspect-ratio: 7/ 10;
		object-fit: cover;
		border-radius: 1.5em;
		/* don't want to see back of cards in front of screen plane */
		backface-visibility: hidden;
		-webkit-backface-visibility: hidden;
		/* need to use a transform chain here, cannot use separate 
		 * rotate & translate properties because they'd be applied 
		 * in wrong order (translate, then rotate) for what we need */
		transform: 
			/* rotate around y axis; in the future: sibling-index() */
			rotatey(calc(var(--i)*var(--ba)))
			/* only after that translate along z axis with minus */
			translatez(calc(-1*(.5*var(--w) + .5em)/tan(.5*var(--ba))));
		/* Mejorar calidad de imagen */
		image-rendering: auto;
		/* Agregar sombra para mejor visualización */
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
	}

	/* Estilos específicos para videos */
	video.card {
		/* Asegurar que el video se reproduzca correctamente */
		pointer-events: none;
		object-fit: cover;
	}

	@media (prefers-reduced-motion: reduce) {
		.a3d {
			animation-duration: 128s;
		}
	}

	/* Tablet: activar clip horizontal para evitar scroll */
	@media (max-width: 1024px) {
		.carousel-wrapper {
			overflow-x: clip;
		}

		.carousel-section {
			padding: 0.75rem 0 6rem;
			/* tablet: subir menos que desktop pero más que antes */
			margin-top: -12rem;
			margin-bottom: 3rem;
		}

		.scene {
			min-height: 600px;
			padding: 4rem 0;
		}

		.card {
			--w: 340px;
		}
	}

	/* Mobile */
	@media (max-width: 768px) {
		.carousel-section {
			padding: 0.5rem 0 5rem;
			/* mobile: subir moderadamente */
			margin-top: -10rem;
			margin-bottom: 2rem;
		}

		.card {
			--w: 300px;
		}
		
		.scene {
			min-height: 550px;
			perspective: 30em;
			padding: 3.5rem 0;
		}
	}

	/* Small mobile */
	@media (max-width: 480px) {
		.carousel-section {
			padding: 0.5rem 0 4rem;
			/* small mobile: subir ligeramente para no tapar contenido */
			margin-top: -6rem;
			margin-bottom: 1.5rem;
		}

		.card {
			--w: 240px;
		}
		
		.scene {
			min-height: 500px;
			perspective: 25em;
			padding: 3rem 0;
		}
	}
</style>
