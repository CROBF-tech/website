---
// Carrusel 3D con efecto de rotación - 12 videos
const items = [
	{ type: 'video' as const, src: '/video_1.mp4', variant: 'default' },      // 1
	{ type: 'video' as const, src: '/hexadevs.mp4', variant: 'default' },     // 2
	{ type: 'video' as const, src: '/video_3.mp4', variant: 'default' },      // 3
	{ type: 'video' as const, src: '/olympo.mp4', variant: 'olympo' },        // 4
	{ type: 'video' as const, src: '/video_4.mp4', variant: 'default' },      // 5
	{ type: 'video' as const, src: '/TodoApp.mp4', variant: 'default' },      // 6
	{ type: 'video' as const, src: '/video_5.mp4', variant: 'default' },      // 7
	{ type: 'video' as const, src: '/video_1.mp4', variant: 'default' },      // 8 (repetido - 7 posiciones después)
	{ type: 'video' as const, src: '/Bunny_Js.mp4', variant: 'default' },     // 9
	{ type: 'video' as const, src: '/hexadevs.mp4', variant: 'default' },     // 10 (repetido - 8 posiciones después)
	{ type: 'video' as const, src: '/flashcards.mp4', variant: 'default' },   // 11
	{ type: 'video' as const, src: '/olympo.mp4', variant: 'olympo' },        // 12 (repetido - 8 posiciones después)
];

const totalCards = items.length;
---

<div class="carousel-wrapper">
	<section class="carousel-section">
		<div class="scene">
			<div class="a3d" style={`--n: ${totalCards}`}>
					{items.map((item, index) => (
						<video
							class="card"
							src={item.src}
							data-variant={item.variant}
							style={`--i: ${index}`}
							autoplay
							muted
							loop
							playsinline
						/>
					))}
			</div>
		</div>
	</section>
</div>

<style>
	.carousel-wrapper {
		width: 100vw;
		margin-left: calc(50% - 50vw);
		margin-right: calc(50% - 50vw);
		position: relative;
	}

	.carousel-section {
		width: 100%;
		padding: 1rem 0 12rem;
		margin-top: -16rem;
		margin-bottom: 4rem;
		display: grid;
		place-items: center;
		position: relative;
		z-index: 999;
		isolation: isolate;
	}

	/* ====== Relevant CSS ====== */
	.scene, 
	.a3d {
		display: grid;
	}

	.scene {
		/* prevent scrollbars */
		overflow: hidden;
		/* for 3D look; smaller = more extreme effect */
		perspective: 35em;
		/* lateral fade */
		mask: linear-gradient(90deg, #0000, red 20% 80%, #0000);
		min-height: 900px;
		width: 100%;
		display: grid;
		place-items: center;
		padding: 8rem 0;
	}

	.a3d {
		place-self: center /* middle align */;
		/* don't flatten 3D transformed children 
		 * of this parent having its own 3D transform */
		transform-style: preserve-3d;
		animation: ry 32s linear infinite;
	}

	/* simplest y axis rotation */
	@keyframes ry {
		to {
			rotate: y 1turn;
		}
	}

	.card {
		/* base card width */
		--w: 17.5em;
		/* compute base angle corresponding to a card */
		--ba: 1turn/var(--n);

		grid-area: 1/ 1 /* stack in same one grid cell */;
		width: var(--w);
		max-width: 90vw;
		aspect-ratio: 7/ 10;
		object-fit: cover;
		border-radius: 1.5em;
		/* don't want to see back of cards in front of screen plane */
		backface-visibility: hidden;
		/* rotate around y axis, then translate along z axis */
		transform:
			rotatey(calc(var(--i)*var(--ba)))
			translatez(calc(-1*(0.5*var(--w) + 0.5em)/tan(0.5*var(--ba))));
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
	}

	/* Estilos específicos para videos */
	video.card {
		pointer-events: none;
		object-fit: cover;
	}

	@media (prefers-reduced-motion: reduce) {
		.a3d {
			animation-duration: 128s;
		}
	}

	/* Tablet */
	@media (max-width: 1024px) {
		.carousel-wrapper {
			overflow-x: clip;
		}

		.carousel-section {
			padding: 0.75rem 0 6rem;
			margin-top: -12rem;
			margin-bottom: 3rem;
		}

		.scene {
			min-height: 600px;
			padding: 4rem 0;
		}

		.card {
			--w: 15em;
		}
	}

	/* Mobile */
	@media (max-width: 768px) {
		.carousel-section {
			padding: 0.5rem 0 5rem;
			margin-top: -10rem;
			margin-bottom: 2rem;
		}

		.card {
			--w: 13em;
		}

		.scene {
			min-height: 550px;
			perspective: 30em;
			padding: 3.5rem 0;
		}
	}

	/* Small mobile */
	@media (max-width: 480px) {
		.carousel-section {
			padding: 0.5rem 0 4rem;
			margin-top: -6rem;
			margin-bottom: 1.5rem;
		}

		.card {
			--w: 11em;
		}

		.scene {
			min-height: 500px;
			perspective: 25em;
			padding: 3rem 0;
		}
	}
</style>
