---
interface Props {}
import { useTranslations, getLangFromUrl } from "../i18n/translate";
const t = useTranslations(getLangFromUrl(Astro.url));
---

<div class="cards-philosophy">
    <div class="card">
        <figure>
            <img src="/svg/aprendizaje.svg" alt="" />
        </figure>
        <h4 set:html={t("about.philosophy.learningDept.title")} />
        <p set:html={t("about.philosophy.learningDept")} />
    </div>
    <div class="card">
        <figure>
            <img src="/svg/ganancias.svg" alt="" />
        </figure>
        <h4 set:html={t("about.philosophy.profitDept.title")} />
        <p set:html={t("about.philosophy.profitDept")} />
    </div>
</div>
<style>
    .cards-philosophy {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
        align-items: stretch;
        width: 100%;
    }
    html.dark .card {
        background-color: #39445b;
    }
    .card {
        font-size: 15px;
        text-align: center;
        padding: 1rem;
        max-width: 300px;
        width: 100%;
        border: solid 1px black;
        border-radius: 12px;
        box-sizing: border-box;
    }
    .card h4 {
        color: var(--accent);
        font-size: 20px;
    }
    @media (max-width: 600px) {
        .cards-philosophy {
            flex-direction: column;
            align-items: center;
        }
        .card {
            max-width: 100%;
        }
    }
</style>
