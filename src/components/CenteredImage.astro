---
interface Props {
    src: string;
    alt: string;
    resize: string;
}

const { src, alt } = Astro.props;
---

<div class="centered-image">
    <img src={src} alt={alt} />
</div>

<style>
    .centered-image {
        width: 100%;
        max-width: 100%;
        text-align: center;
        box-sizing: border-box;
    }

    .centered-image img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        display: inline-block;
    }

    @media (min-width: 641px) {
        .centered-image img {
            max-width: 90%;
        }
    }
</style>
