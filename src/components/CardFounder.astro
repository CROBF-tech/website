---
import { getLangFromUrl } from "../i18n/translate";
import Github from "./svgs/Github.astro";
import Linkedin from "./svgs/Linkedin.astro";
const { name, image, github, linkedin, link, profession, description } = Astro.props;
const lang = getLangFromUrl(Astro.url);

// Seleccionar imagen aleatoria si es un array
const selectedImage = Array.isArray(image) 
    ? image[Math.floor(Math.random() * image.length)]
    : image;
---

<div class="card" onclick={`window.location.href='/${lang}${link}'`}>
    <div class="card-image-container">
        {selectedImage && <img src={selectedImage} alt={`Imagen del integrante ${name}`} />}
    </div>

    <div class="card-content">
        <div class="card-header">
            <h3 class="card-name">{name}</h3>
            <p class="card-profession">{profession}</p>
        </div>

        <div class="card-socials">
            <a
                href={`${github}`}
                target="_blank"
                aria-label={`Link para github de ${name}`}
                onclick="this.event.stopPropagation();"
                class="social-link">
                <Github />
            </a>
            <a
                href={`${linkedin}`}
                target="_blank"
                aria-label={`Link para linkedin de ${name}`}
                onclick="this.event.stopPropagation();"
                class="social-link">
                <Linkedin />
            </a>
        </div>
    </div>
</div>

<style>
    .card {
        position: relative;
        width: 100%;
        max-width: 560px;
        background: transparent;
        border-radius: 12px;
        overflow: hidden;
        transition: all 0.18s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 18px;
        padding: 12px 14px;
        border: 1px solid rgba(0,0,0,0.06);
    }

    :global(html.dark) .card {
        background: transparent !important;
        border: 1px solid rgba(255,255,255,0.06);
        box-shadow: none;
    }

    .card:hover {
        transform: translateY(-6px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    }

    :global(html.dark) .card:hover {
        box-shadow: none;
    }

    .card-image-container {
        width: 96px;
        height: 96px;
        border-radius: 999px;
        overflow: hidden;
        flex: 0 0 96px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(180deg, rgba(0,0,0,0.03), rgba(0,0,0,0.02));
    }

    .card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.25s ease;
    }

    .card:hover img {
        transform: scale(1.03);
    }

    .card-overlay { display:none; }

    .card-socials {
        display: flex;
        gap: 10px;
        margin-top: 6px;
    }

    .social-link {
        width: 38px;
        height: 38px;
        background: rgba(0,0,0,0.06);
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.18s ease, background 0.18s ease;
        border: 1px solid rgba(0,0,0,0.06);
    }

    .social-link:hover {
        transform: translateY(-3px) scale(1.04);
        background: rgba(0,0,0,0.1);
    }

    .social-link svg {
        width: 18px;
        height: 18px;
        fill: currentColor;
    }

    .card-content {
        padding: 0;
        flex: 1 1 auto;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
    }

    .card-name {
        font-size: 1.15rem;
        font-weight: 700;
        margin: 0;
        color: var(--color-bright-gray-950);
        line-height: 1.05;
    }

    :global(html.dark) .card-name {
        color: var(--color-bright-gray-50);
    }

    .card-profession {
        font-size: 0.85rem;
        font-weight: 600;
        margin: 6px 0 0;
        color: var(--accent);
        text-transform: none;
        letter-spacing: 0.2px;
    }

    :global(html.dark) .card-profession {
        color: var(--color-blue-100);
    }

    /* description removed by design */

    /* Responsive Design */
    @media (max-width: 768px) {
        .card {
            gap: 12px;
            padding: 10px 12px;
        }

        .card-image-container {
            width: 84px;
            height: 84px;
            flex: 0 0 84px;
        }

        .social-link {
            width: 34px;
            height: 34px;
            border-radius: 9px;
        }
    }

    @media (max-width: 480px) {
        .card-image-container {
            width: 64px;
            height: 64px;
            flex: 0 0 64px;
        }

        .card-name {
            font-size: 1rem;
        }

        .card-profession {
            font-size: 0.8rem;
        }
    }
</style>
