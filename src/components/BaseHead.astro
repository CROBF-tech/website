---
import "../styles/global.scss";
import "../styles/navbar.css";
import { SEO } from "astro-seo";
import Analytics from "@vercel/analytics/astro";

interface Props {
    title: string;
    description: string;
    image?: string;
    type?: "website" | "article";
    lang?: "es" | "en";
    publishedTime?: string;
    author?: string;
}

const { title, description, image = "/Logo1120x1120.png", type = "website", lang = "es", publishedTime, author } = Astro.props;

const ogLocale = lang === "en" ? "en_US" : "es_AR";
---

<SEO
    title={title}
    description={description}
    canonical={Astro.url.pathname}
    charset="utf-8"
    openGraph={{
        basic: {
            title: title,
            type: type,
            image: image,
            url: Astro.url.toString(),
        },
        optional: {
            description: description,
            locale: ogLocale,
            siteName: "CROBF",
            ...(publishedTime ? { publishedTime } : {}),
            ...(author ? { authors: [author] } : {}),
        },
        image: {
            alt: "CROBF - Web, apps y automatización para tu negocio",
        },
    }}
    twitter={{
        card: "summary_large_image",
        title: title,
        description: description,
        image: image,
        imageAlt: "CROBF - Web, apps y automatización para tu negocio",
    }}
    extend={{
        link: [
            { rel: "icon", type: "image/png", href: "/Logo360x360Icon.png" },
            { rel: "preload", href: "/fonts/atkinson-regular.woff", as: "font", type: "font/woff", crossorigin: "anonymous" },
            { rel: "preload", href: "/fonts/atkinson-bold.woff", as: "font", type: "font/woff", crossorigin: "anonymous" },
            ...(lang === "en" ? [{ rel: "alternate", hreflang: "es", href: Astro.url.toString().replace(`/${lang}/`, "/es/") }, { rel: "alternate", hreflang: "en", href: Astro.url.toString() }] : [{ rel: "alternate", hreflang: "es", href: Astro.url.toString() }, { rel: "alternate", hreflang: "en", href: Astro.url.toString().replace(`/${lang}/`, "/en/") }]),
        ],
        meta: [
            { name: "viewport", content: "width=device-width,initial-scale=1" },
            { name: "generator", content: Astro.generator },
        ],
    }}
/>
<Analytics />
