---
import { useTranslations, getLangFromUrl } from "../i18n/translate";
const MAIL_KEY = import.meta.env.MAIL_KEY;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div class="contact-form">
    <div class="form-panel">
        <div class="form-header">
            <h2 class="heading">{t("form.contact.title")}</h2>
            <p class="sub">{t("form.contact.description") ?? "Need help with something? Get in touch and we’ll reply shortly."}</p>
        </div>

        <form method="POST" id="contact_form">
            <input type="hidden" name="access_key" value={MAIL_KEY} />

            <div class="field">
                <label for="name">{t("form.contact.name")}</label>
                <input type="text" name="name" placeholder="Jhon Doe" required="" />
            </div>

            <div class="field">
                <label for="email">{t("form.contact.email")}</label>
                <input type="email" id="email" name="email" placeholder="jhondoe@email.com" required="" />
            </div>

            <div class="field">
                <label for="message">{t("form.contact.message")}</label>
                <textarea id="message" name="message" placeholder={t("form.contact.placeholder.message") as string} required=""></textarea>
            </div>

            <div class="actions">
                <button type="submit">{t("form.contact.submit")}</button>
            </div>

            <div class="result"></div>
        </form>
    </div>

    <div class="visual-panel" aria-hidden="true">
        <!-- Decorative side: large image or gradient to match reference -->
        <div class="visual-content">
                <video class="panel-video" src="/video_formulario.mp4" autoplay muted loop playsinline></video>
            </div>
    </div>
</div>
<script is:inline>
    const form = document.getElementById("contact_form");
    const result = document.querySelector(".result");

    form.addEventListener("submit", async function (e) {
        const formData = new FormData(form);
        e.preventDefault();

        try {
            const json = JSON.stringify(Object.fromEntries(formData));

            result.classList.add("wait");
            result.innerHTML = "Please wait...";

            const response = await fetch("https://api.web3forms.com/submit", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Accept: "application/json",
                },
                body: json,
            });

            const data = await response.json();

            if (data.status === 400) throw new Error();

            console.log(data);

            result.classList.replace("wait", "success");
            result.innerHTML = "Se envió el mensaje correctamente";
        } catch (e) {
            result.classList.replace("wait", "error");
            result.innerHTML = "Hubo un error al enviar tu mensaje";
        } finally {
            form.reset();
        }
    });
</script>
<style>
    .contact-form {
        max-width: 900px;
        width: 100%;
        margin: 2rem auto;
        display: flex;
        gap: 0;
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0,0,0,0.45);
    }

    .result {
        display: none;
        padding: 0.5rem 0;
        border-radius: 12px;
        text-align: center;
        margin-top: 10px;
    }

    .result.wait { border: solid 2px #bfdd17; background-color: #bad4263b; }
    .result.success { border: solid 2px #2f790c; background-color: #5ac7283b; }
    .result.error { border: solid 2px #920e0e; background-color: #c526263b; }

    .form-panel {
        flex: 1 1 420px;
        background-color: #0f1113;
        color: #fff;
        padding: 36px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 12px;
    }

    .visual-panel {
        flex: 1 1 480px;
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
        display: block;
        padding: 0; /* remove padding so video can fill */
        overflow: hidden;
        position: relative; /* allow absolute video to fill */
    }

    html.dark .visual-panel { background: linear-gradient(180deg, rgba(0,0,0,0.15), rgba(0,0,0,0.1)); }

    .form-header .heading { line-height: 1.05; font-size: 1.8rem; color: #fff; margin: 0 0 8px 0; font-weight: 700; }
    .form-header .sub { margin: 0 0 18px 0; color: rgba(255,255,255,0.72); font-size: 0.95rem; }

    .form-panel form { display: flex; flex-direction: column; gap: 12px; }

    .field label { display:block; font-size:0.85rem; color: rgba(255,255,255,0.75); margin-bottom:6px; }
    .field input, .field textarea {
        background: transparent; border: none; border-bottom: 1px solid rgba(255,255,255,0.12);
        padding: 12px 6px; color:#fff; font-size:1rem;
    }
    .field input::placeholder, .field textarea::placeholder { color: rgba(255,255,255,0.45); }
    .field textarea { min-height:120px; width:100%; resize:none; }

    .field input:focus, .field textarea:focus {
        outline:none; border-bottom-color:var(--accent); box-shadow:0 6px 24px rgba(0,0,0,0.25);
        transform: translateY(-2px); transition: all 0.18s ease;
    }

    .actions { margin-top:6px; }
    .actions button[type="submit"]{
        background:#fff; color:#0b0b0b; border:none; border-radius:999px; padding:12px 26px; font-size:1rem; font-weight:700;
        cursor:pointer; box-shadow:0 6px 18px rgba(0,0,0,0.28);
    }
    .actions button[type="submit"]:hover{ transform: translateY(-2px); transition: transform 0.18s ease; }

    .visual-content { max-width: 420px; }
    .visual-content { width:100%; height:100%; display:block; position:relative; }
    .visual-content .quote { font-size: 1.05rem; color: rgba(0,0,0,0.85); font-weight:700; margin-bottom:16px; }
    html.dark .visual-content .quote { color: rgba(255,255,255,0.95); }
    .visual-content .credit { font-size:0.9rem; color: rgba(0,0,0,0.6); }
    html.dark .visual-content .credit { color: rgba(255,255,255,0.6); }

    .panel-video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    @media (max-width: 900px) {
        .contact-form { flex-direction: column; }
        .visual-panel { order: 2; min-height: 220px; }
        .form-panel { padding: 20px; }
    }
</style>
