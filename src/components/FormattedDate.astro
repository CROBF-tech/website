---
interface Props {
    date: Date;
    lang?: "es" | "en";
}

const { date, lang = "es" } = Astro.props;

const locale = lang === "en" ? "en-us" : "es";
---

<time datetime={date.toISOString()}>
    {
        date.toLocaleDateString(locale, {
            year: "numeric",
            month: "short",
            day: "numeric",
        })
    }
</time>
