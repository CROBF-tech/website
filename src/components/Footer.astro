---
import Github from "./svgs/Github.astro";
import Linkedin from "./svgs/Linkedin.astro";
import Instagram from "./svgs/Instagram.astro";
import X from "./svgs/X.astro";
import { getLangFromUrl } from "../i18n/translate";

const today = new Date();
const lang = getLangFromUrl(Astro.url);
const homeHref = `/${lang}`;
---

<!-- The "Curtain Reveal" Wrapper -->
<div class="footer-curtain-wrapper">
    <!-- The actual footer stays fixed to the viewport underneath everything -->
    <footer class="cinematic-footer">
        <!-- Ambient Light & Grid Background -->
        <div class="footer-aurora"></div>

        <!-- Diagonal Sleek Marquee (Top of footer) -->
        <div class="footer-marquee-wrapper">
            <div class="footer-marquee-content">
                <div class="footer-marquee-item">
                    <span>Desarrollo de Software</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Diseño UX/UI</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Consultoría Tech</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Soluciones a Medida</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Innovación Digital</span>
                    <span class="footer-marquee-dot">✦</span>
                </div>
                <div class="footer-marquee-item">
                    <span>Desarrollo de Software</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Diseño UX/UI</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Consultoría Tech</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Soluciones a Medida</span>
                    <span class="footer-marquee-dot">✦</span>
                    <span>Innovación Digital</span>
                    <span class="footer-marquee-dot">✦</span>
                </div>
            </div>
        </div>

        <!-- Giant background text -->
        <div class="footer-giant-bg-text" data-footer-giant>CROBF</div>

        <!-- Main Center Content -->
        <div class="footer-main-content">
            <h2 class="footer-heading" data-footer-heading>¿Digitalizamos tu negocio?</h2>

            <!-- Interactive Links Layout -->
            <div class="footer-links-container" data-footer-links>
                <!-- Primary Link -->
                <a href={`${homeHref}/contact`} class="footer-glass-pill footer-pill-primary" data-magnetic>
                    <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    Contáctanos
                </a>
            </div>
        </div>

        <!-- Bottom Bar / Credits -->
        <div class="footer-bottom-bar">
            <!-- Copyright -->
            <div class="footer-copyright">
                © {today.getFullYear()} CROBF. Todos los derechos reservados.
            </div>

            <!-- Social Links Badge -->
            <div class="footer-social-badge">
                <span class="footer-social-label">Síguenos</span>
                <div class="footer-social-icons">
                    <a href="https://github.com/CROBF-tech" target="_blank" aria-label="GitHub de CROBF" class="footer-social-link" data-magnetic>
                        <Github />
                    </a>
                    <a href="https://www.linkedin.com/company/crobf/" target="_blank" aria-label="LinkedIn de CROBF" class="footer-social-link" data-magnetic>
                        <Linkedin />
                    </a>
                    <a href="https://x.com/CROBF_arg" target="_blank" aria-label="X de CROBF" class="footer-social-link" data-magnetic>
                        <X />
                    </a>
                    <a href="https://www.instagram.com/crobf_tech/" target="_blank" aria-label="Instagram de CROBF" class="footer-social-link" data-magnetic>
                        <Instagram />
                    </a>
                </div>
            </div>

            <!-- Back to top -->
            <button class="footer-back-to-top" data-magnetic data-scroll-top aria-label="Volver arriba">
                <svg class="footer-arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                </svg>
            </button>
        </div>
    </footer>
</div>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    // Magnetic effect for buttons
    function initMagneticButtons() {
        const magneticElements = document.querySelectorAll("[data-magnetic]");

        magneticElements.forEach((element) => {
            const handleMouseMove = (e: MouseEvent) => {
                const rect = element.getBoundingClientRect();
                const h = rect.width / 2;
                const w = rect.height / 2;
                const x = e.clientX - rect.left - h;
                const y = e.clientY - rect.top - w;

                gsap.to(element, {
                    x: x * 0.4,
                    y: y * 0.4,
                    rotationX: -y * 0.15,
                    rotationY: x * 0.15,
                    scale: 1.05,
                    ease: "power2.out",
                    duration: 0.4,
                });
            };

            const handleMouseLeave = () => {
                gsap.to(element, {
                    x: 0,
                    y: 0,
                    rotationX: 0,
                    rotationY: 0,
                    scale: 1,
                    ease: "elastic.out(1, 0.3)",
                    duration: 1.2,
                });
            };

            element.addEventListener("mousemove", handleMouseMove);
            element.addEventListener("mouseleave", handleMouseLeave);
        });
    }

    // Scroll animations
    function initScrollAnimations() {
        const giantText = document.querySelector("[data-footer-giant]");
        const heading = document.querySelector("[data-footer-heading]");
        const links = document.querySelector("[data-footer-links]");
        const wrapper = document.querySelector(".footer-curtain-wrapper");

        if (!wrapper) return;

        // Background Parallax
        if (giantText) {
            gsap.fromTo(
                giantText,
                { y: "10vh", scale: 0.8, opacity: 0 },
                {
                    y: "0vh",
                    scale: 1,
                    opacity: 1,
                    ease: "power1.out",
                    scrollTrigger: {
                        trigger: wrapper,
                        start: "top 80%",
                        end: "bottom bottom",
                        scrub: 1,
                    },
                }
            );
        }

        // Staggered Content Reveal
        if (heading && links) {
            gsap.fromTo(
                [heading, links],
                { y: 50, opacity: 0 },
                {
                    y: 0,
                    opacity: 1,
                    stagger: 0.15,
                    ease: "power3.out",
                    scrollTrigger: {
                        trigger: wrapper,
                        start: "top 40%",
                        end: "bottom bottom",
                        scrub: 1,
                    },
                }
            );
        }
    }

    // Scroll to top
    function initScrollToTop() {
        const scrollTopBtn = document.querySelector("[data-scroll-top]");
        if (scrollTopBtn) {
            scrollTopBtn.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });
        }
    }

    // Initialize all
    document.addEventListener("DOMContentLoaded", () => {
        initMagneticButtons();
        initScrollAnimations();
        initScrollToTop();
    });
</script>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap');

    /* Curtain Reveal Wrapper */
    .footer-curtain-wrapper {
        position: relative;
        height: 100vh;
        width: 100%;
        clip-path: polygon(0% 0, 100% 0%, 100% 100%, 0 100%);
    }

    /* Main Footer */
    .cinematic-footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        background: hsl(var(--background));
        color: hsl(var(--foreground));
        font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        -webkit-font-smoothing: antialiased;
    }

    /* Aurora Glow */
    .footer-aurora {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 80vw;
        height: 60vh;
        transform: translate(-50%, -50%);
        background: radial-gradient(
            circle at 50% 50%,
            rgba(78, 111, 247, 0.15) 0%,
            rgba(95, 126, 252, 0.1) 40%,
            transparent 70%
        );
        border-radius: 50%;
        filter: blur(80px);
        animation: footer-breathe 8s ease-in-out infinite alternate;
        pointer-events: none;
        z-index: 0;
    }

    :global(html.dark) .footer-aurora {
        background: radial-gradient(
            circle at 50% 50%,
            rgba(78, 111, 247, 0.2) 0%,
            rgba(95, 126, 252, 0.15) 40%,
            transparent 70%
        );
    }

    @keyframes footer-breathe {
        0% {
            transform: translate(-50%, -50%) scale(1);
            opacity: 0.6;
        }
        100% {
            transform: translate(-50%, -50%) scale(1.1);
            opacity: 1;
        }
    }

    /* Diagonal Marquee */
    .footer-marquee-wrapper {
        position: absolute;
        top: 8rem;
        left: 0;
        width: 100%;
        overflow: hidden;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        padding: 0.5rem 0;
        z-index: 10;
        transform: rotate(-2deg) scale(1.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    :global(html.dark) .footer-marquee-wrapper {
        background: rgba(0, 0, 0, 0.4);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    }

    .footer-marquee-content {
        display: flex;
        width: max-content;
        animation: footer-scroll-marquee 40s linear infinite;
    }

    @keyframes footer-scroll-marquee {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }

    .footer-marquee-item {
        display: flex;
        align-items: center;
        gap: 3rem;
        padding: 0 1.5rem;
        font-size: clamp(0.75rem, 1.5vw, 0.875rem);
        font-weight: 700;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: hsl(var(--foreground) / 0.6);
        white-space: nowrap;
    }

    .footer-marquee-dot {
        color: rgba(78, 111, 247, 0.6);
        font-size: 0.75rem;
    }

    :global(html.dark) .footer-marquee-dot {
        color: rgba(95, 126, 252, 0.6);
    }

    /* Giant Background Text */
    .footer-giant-bg-text {
        position: absolute;
        bottom: -5vh;
        left: 50%;
        transform: translateX(-50%);
        font-size: 26vw;
        line-height: 0.75;
        font-weight: 900;
        letter-spacing: -0.05em;
        color: transparent;
        -webkit-text-stroke: 1px rgba(0, 0, 0, 0.05);
        background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, transparent 60%);
        -webkit-background-clip: text;
        background-clip: text;
        white-space: nowrap;
        pointer-events: none;
        user-select: none;
        z-index: 0;
    }

    :global(html.dark) .footer-giant-bg-text {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.05);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.1) 0%, transparent 60%);
        -webkit-background-clip: text;
        background-clip: text;
    }

    /* Main Content */
    .footer-main-content {
        position: relative;
        z-index: 10;
        display: flex;
        flex: 1;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 0 1.5rem;
        margin-top: 5rem;
        width: 100%;
        max-width: 80rem;
        margin-left: auto;
        margin-right: auto;
    }

    .footer-heading {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 900;
        background: linear-gradient(180deg, 
            rgba(255, 255, 255, 0.95) 0%, 
            rgba(180, 180, 180, 0.7) 50%,
            rgba(120, 120, 120, 0.5) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0px 2px 40px rgba(255, 255, 255, 0.3));
        letter-spacing: -0.02em;
        margin-bottom: 3rem;
        text-align: center;
        line-height: 1.1;
    }

    :global(html:not(.dark)) .footer-heading {
        background: linear-gradient(180deg, 
            rgba(60, 60, 60, 0.98) 0%, 
            rgba(90, 90, 90, 0.85) 50%,
            rgba(120, 120, 120, 0.7) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0px 2px 20px rgba(0, 0, 0, 0.1));
    }

    :global(html.dark) .footer-heading {
        background: linear-gradient(180deg, 
            rgba(255, 255, 255, 0.98) 0%, 
            rgba(200, 200, 200, 0.75) 50%,
            rgba(140, 140, 140, 0.55) 100%
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0px 2px 40px rgba(255, 255, 255, 0.4));
    }

    /* Links Container */
    .footer-links-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        width: 100%;
        justify-content: center;
    }

    /* Glass Pills */
    .footer-glass-pill {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
        box-shadow: 
            0 10px 30px -10px rgba(0, 0, 0, 0.1),
            inset 0 1px 1px rgba(255, 255, 255, 0.1),
            inset 0 -1px 2px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-radius: 9999px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        text-decoration: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
    }

    :global(html.dark) .footer-glass-pill {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .footer-glass-pill:hover {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
        border-color: rgba(255, 255, 255, 0.2);
        box-shadow: 
            0 20px 40px -10px rgba(0, 0, 0, 0.2),
            inset 0 1px 1px rgba(255, 255, 255, 0.2);
    }

    :global(html.dark) .footer-glass-pill:hover {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0.03) 100%);
        border-color: rgba(255, 255, 255, 0.25);
    }

    .footer-pill-primary {
        padding: 1.25rem 2.5rem;
        font-size: clamp(0.875rem, 2vw, 1rem);
        font-weight: 700;
        color: hsl(var(--foreground)) !important;
    }

    .footer-pill-primary:hover {
        color: hsl(var(--foreground)) !important;
    }

    .footer-pill-secondary {
        padding: 0.75rem 1.5rem;
        font-size: clamp(0.75rem, 1.5vw, 0.875rem);
        font-weight: 600;
        color: hsl(var(--foreground) / 0.7) !important;
    }

    .footer-pill-secondary:hover {
        color: hsl(var(--foreground)) !important;
    }

    .footer-icon {
        width: 1.5rem;
        height: 1.5rem;
        color: hsl(var(--foreground) / 0.6);
        transition: color 0.3s ease;
    }

    .footer-glass-pill:hover .footer-icon {
        color: hsl(var(--foreground)) !important;
    }

    /* Bottom Bar */
    .footer-bottom-bar {
        position: relative;
        z-index: 20;
        width: 100%;
        padding: 2rem clamp(1.5rem, 3vw, 3rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .footer-bottom-bar {
            flex-direction: row;
        }
    }

    .footer-copyright {
        color: hsl(var(--foreground) / 0.5);
        font-size: clamp(0.625rem, 1.5vw, 0.75rem);
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        order: 2;
    }

    @media (min-width: 768px) {
        .footer-copyright {
            order: 1;
        }
    }

    /* Social Badge */
    .footer-social-badge {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
        box-shadow: 
            0 10px 30px -10px rgba(0, 0, 0, 0.1),
            inset 0 1px 1px rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-radius: 9999px;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        order: 1;
        margin-left: auto;
    }

    @media (min-width: 768px) {
        .footer-social-badge {
            order: 2;
            margin-left: auto;
            margin-right: 1rem;
        }
    }

    :global(html.dark) .footer-social-badge {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .footer-social-label {
        color: hsl(var(--foreground) / 0.5);
        font-size: clamp(0.625rem, 1.5vw, 0.75rem);
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .footer-social-icons {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .footer-social-link {
        color: hsl(var(--foreground) / 0.6);
        transition: color 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .footer-social-link:hover {
        color: hsl(var(--foreground));
    }

    .footer-social-link :global(svg) {
        width: 1.25rem;
        height: 1.25rem;
    }

    /* Back to Top Button */
    .footer-back-to-top {
        width: 3rem;
        height: 3rem;
        border-radius: 9999px;
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.01) 100%);
        box-shadow: 
            0 10px 30px -10px rgba(0, 0, 0, 0.1),
            inset 0 1px 1px rgba(255, 255, 255, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        display: flex;
        align-items: center;
        justify-content: center;
        color: hsl(var(--foreground) / 0.6);
        cursor: pointer;
        transition: all 0.3s ease;
        order: 3;
    }

    :global(html.dark) .footer-back-to-top {
        background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .footer-back-to-top:hover {
        color: hsl(var(--foreground));
        transform: translateY(-0.25rem);
    }

    .footer-arrow-icon {
        width: 1.25rem;
        height: 1.25rem;
        transition: transform 0.3s ease;
    }

    .footer-back-to-top:hover .footer-arrow-icon {
        transform: translateY(-0.375rem);
    }

    @media (max-width: 640px) {
        .footer-main-content {
            margin-top: 3rem;
        }

        .footer-heading {
            margin-bottom: 2rem;
        }

        .footer-pill-primary {
            padding: 1rem 2rem;
        }

        .footer-bottom-bar {
            padding: 1.5rem 1rem;
        }
    }
</style>
