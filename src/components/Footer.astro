---
import Github from "./svgs/Github.astro";
import Linkedin from "./svgs/Linkedin.astro";
import Instagram from "./svgs/Instagram.astro";
import X from "./svgs/X.astro";
import { getLangFromUrl } from "../i18n/translate";

const today = new Date();
const lang = getLangFromUrl(Astro.url);
const homeHref = `/${lang}`;
---

<footer class="cinematic-footer">
    <!-- Background Elements -->
    <div class="footer-giant-bg-text">CROBF</div>
    
    <!-- Marquee Line -->
    <div class="footer-marquee-wrapper">
        <div class="footer-marquee-content">
            {Array(3).fill(0).map(() => (
                <div class="footer-marquee-item">
                    <span>Desarrollo de Software</span>
                    <span class="footer-marquee-dot"><img src="/Logo360x360Icon.png" alt="CROBF" /></span>
                    <span>Diseño UX/UI</span>
                    <span class="footer-marquee-dot"><img src="/Logo360x360Icon.png" alt="CROBF" /></span>
                    <span>Consultoría Tech</span>
                    <span class="footer-marquee-dot"><img src="/Logo360x360Icon.png" alt="CROBF" /></span>
                    <span>Soluciones a Medida</span>
                    <span class="footer-marquee-dot"><img src="/Logo360x360Icon.png" alt="CROBF" /></span>
                    <span>Innovación Digital</span>
                    <span class="footer-marquee-dot"><img src="/Logo360x360Icon.png" alt="CROBF" /></span>
                </div>
            ))}
        </div>
    </div>

    <!-- Main Content -->
    <div class="footer-main-content">
        <h2 class="footer-heading">¿Digitalizamos tu negocio?</h2>
        
        <div class="footer-links-container">
            <a href={`${homeHref}/contact`} class="footer-glass-pill footer-pill-primary">
                <svg class="footer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                Contáctanos
            </a>
        </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom-bar">
        <div class="footer-copyright">
            © {today.getFullYear()} CROBF. Todos los derechos reservados.
        </div>

        <div class="footer-social-badge">
            <span class="footer-social-label">Síguenos</span>
            <div class="footer-social-icons">
                <a href="https://github.com/CROBF-tech" target="_blank" aria-label="GitHub de CROBF" class="footer-social-link">
                    <Github />
                </a>
                <a href="https://www.linkedin.com/company/crobf/" target="_blank" aria-label="LinkedIn de CROBF" class="footer-social-link">
                    <Linkedin />
                </a>
                <a href="https://x.com/CROBF_arg" target="_blank" aria-label="X de CROBF" class="footer-social-link">
                    <X />
                </a>
                <a href="https://www.instagram.com/crobf_tech/" target="_blank" aria-label="Instagram de CROBF" class="footer-social-link">
                    <Instagram />
                </a>
            </div>
        </div>
    </div>
</footer>

<style>
    .cinematic-footer {
        /* Ultimate Edge-to-Edge Breakout Formula */
        position: relative;
        width: 100vw;
        left: 50%;
        transform: translateX(-50%);
        min-height: 600px;
        background: hsl(var(--background));
        color: hsl(var(--foreground));
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding-top: 120px;
        isolation: isolate;
        z-index: 10;
    }

    /* Giant Background Text */
    .footer-giant-bg-text {
        position: absolute;
        bottom: -5%;
        left: 50%;
        transform: translateX(-50%);
        font-size: 25vw;
        line-height: 0.8;
        font-weight: 950;
        letter-spacing: -0.05em;
        color: transparent;
        -webkit-text-stroke: 1px hsl(var(--foreground) / 0.1);
        background: linear-gradient(180deg, hsl(var(--foreground) / 0.15) 0%, transparent 80%);
        -webkit-background-clip: text;
        background-clip: text;
        white-space: nowrap;
        pointer-events: none;
        user-select: none;
        z-index: -1;
    }

    /* Marquee */
    .footer-marquee-wrapper {
        position: absolute;
        top: 40px;
        left: 0;
        width: 100%;
        padding: 15px 0;
        background: hsl(var(--background) / 0.8);
        backdrop-filter: blur(8px);
        border-top: 1px solid hsl(var(--foreground) / 0.1);
        border-bottom: 1px solid hsl(var(--foreground) / 0.1);
        z-index: 20;
        overflow: hidden;
    }

    .footer-marquee-content {
        display: flex;
        width: max-content;
        animation: footer-scroll-marquee 60s linear infinite;
    }

    @keyframes footer-scroll-marquee {
        from { transform: translateX(0); }
        to { transform: translateX(-33.33%); }
    }

    .footer-marquee-item {
        display: flex;
        align-items: center;
        gap: 3rem;
        padding: 0 1.5rem;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: hsl(var(--foreground) / 0.8);
    }

    .footer-marquee-dot img {
        width: 1.5rem;
        height: 1.5rem;
        opacity: 1;
    }

    /* Main Content */
    .footer-main-content {
        position: relative;
        z-index: 5;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex: 1;
        padding: 60px 20px;
        text-align: center;
    }

    .footer-heading {
        font-size: clamp(2.5rem, 8vw, 5rem);
        font-weight: 900;
        line-height: 1.1;
        margin-bottom: 40px;
        color: hsl(var(--foreground));
        max-width: 15ch;
        opacity: 1 !important;
        visibility: visible !important;
    }

    .footer-links-container {
        opacity: 1 !important;
        visibility: visible !important;
    }

    .footer-glass-pill {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem 2.5rem;
        border-radius: 9999px;
        background: hsl(var(--foreground) / 0.05);
        border: 1px solid hsl(var(--foreground) / 0.15);
        backdrop-filter: blur(12px);
        text-decoration: none;
        color: hsl(var(--foreground));
        font-weight: 800;
        transition: all 0.3s ease;
    }

    .footer-glass-pill:hover {
        background: hsl(var(--foreground) / 0.1);
        transform: translateY(-4px);
        border-color: hsl(var(--foreground) / 0.3);
    }

    .footer-icon {
        width: 1.5rem;
        height: 1.5rem;
    }

    /* Bottom Bar */
    .footer-bottom-bar {
        position: relative;
        z-index: 30;
        width: 100%;
        padding: 40px 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        border-top: 1px solid hsl(var(--foreground) / 0.1);
        background: hsl(var(--background));
    }

    @media (min-width: 768px) {
        .footer-bottom-bar {
            flex-direction: row;
            padding: 40px 60px;
        }
    }

    .footer-copyright {
        font-size: 0.8rem;
        color: hsl(var(--foreground) / 0.6);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .footer-social-badge {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        padding: 0.75rem 1.5rem;
        background: hsl(var(--foreground) / 0.05);
        border: 1px solid hsl(var(--foreground) / 0.1);
        border-radius: 9999px;
    }

    .footer-social-label {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: hsl(var(--foreground) / 0.5);
    }

    .footer-social-icons {
        display: flex;
        gap: 1.25rem;
    }

    .footer-social-link {
        color: hsl(var(--foreground) / 0.7);
        transition: all 0.3s ease;
    }

    .footer-social-link:hover {
        color: hsl(var(--foreground));
        transform: translateY(-2px);
    }

    .footer-social-link :global(svg) {
        width: 1.5rem;
        height: 1.5rem;
    }

    /* Responsive Adjustments */
    @media (max-width: 768px) {
        .cinematic-footer {
            padding-top: 70px;
            min-height: auto;
            height: auto;
        }

        .footer-marquee-wrapper {
            top: 15px;
            padding: 8px 0;
        }

        .footer-giant-bg-text {
            font-size: 40vw;
            bottom: 5%;
            opacity: 0.12;
        }

        .footer-main-content {
            padding: 30px 20px 40px;
        }

        .footer-heading {
            font-size: clamp(1.8rem, 8vw, 2.8rem);
            margin-bottom: 25px;
        }

        .footer-glass-pill {
            padding: 0.85rem 1.75rem;
            width: auto;
            min-width: 220px;
        }

        .footer-bottom-bar {
            padding: 25px 20px;
            gap: 15px;
        }

        .footer-copyright {
            order: 2;
            font-size: 0.7rem;
            text-align: center;
            opacity: 0.8;
            letter-spacing: 0.02em;
        }

        .footer-social-badge {
            order: 1;
            padding: 0.5rem 1rem;
            gap: 1rem;
        }
    }

    @media (max-width: 480px) {
        .footer-giant-bg-text {
            font-size: 45vw;
        }
        
        .footer-marquee-item {
            gap: 1.5rem;
            font-size: 0.65rem;
        }
    }
</style>
