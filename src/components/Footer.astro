---
import Github from "./svgs/Github.astro";
import Linkedin from "./svgs/Linkedin.astro";
import Instagram from "./svgs/Instagram.astro";
import X from "./svgs/X.astro";

const today = new Date();
---

<footer>
    <div class="footer-top">
        <p class="brand">CROBF</p>
        <div class="social-links">
            <a href="https://github.com/CROBF-tech" target="_blank" aria-label="Link del GitHub de CROBF">
                <Github />
            </a>
            <a href="https://www.linkedin.com/company/crobf/" target="_blank" aria-label="Link del Linkedin de CROBF">
                <Linkedin />
            </a>
            <a href="https://x.com/CROBF_arg" target="_blank" aria-label="Link del X de CROBF">
                <X />
            </a>
            <a href="https://www.instagram.com/crobf_tech/" target="_blank" aria-label="Link del Instagram de CROBF">
                <Instagram />
            </a>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; {today.getFullYear()} CROBF. All rights reserved.</p>
    </div>
</footer>
<style>
    footer {
        padding: 2.5em 1em 5.6em 1em;
        background: linear-gradient(var(--gray-gradient)) no-repeat;
        color: rgb(var(--gray));
        width: min(1120px, calc(100% - 2.2rem));
        margin: 0 auto;
        border-radius: 1rem 1rem 0 0;
    }

    html.dark footer {
        background: #0a101f !important;
        color: rgb(var(--white)) !important;
        border: 1px solid rgba(118, 137, 208, 0.22);
        border-bottom: none;
    }

    .footer-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .brand {
        margin: 0;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.06em;
    }

    .social-links {
        display: flex;
        justify-content: flex-end;
        gap: 1em;
    }

    .social-links a {
        text-decoration: none;
        color: rgb(var(--gray));
    }

    html.dark .social-links a {
        color: rgba(237, 241, 255, 0.85);
    }

    .social-links a:hover {
        color: rgb(var(--gray-dark));
    }

    html.dark .social-links a:hover {
        color: #7e97ff;
    }

    .footer-bottom {
        margin-top: 1.1rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(100, 117, 167, 0.2);
        text-align: center;
    }

    .footer-bottom p {
        margin: 0;
        font-size: 0.78rem;
        letter-spacing: 0.02em;
    }

    @media (max-width: 760px) {
        footer {
            padding: 1.7em 0.9em 5em 0.9em;
        }

        .footer-top {
            flex-direction: column;
            align-items: flex-start;
        }

        .social-links {
            justify-content: flex-start;
        }
    }
</style>
