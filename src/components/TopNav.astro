---
import { getLangFromUrl } from "../i18n/translate";

const lang = getLangFromUrl(Astro.url);
const homeHref = `/${lang}`;

const links = [
    { href: homeHref, label: "Inicio" },
    { href: `${homeHref}/#casos-exito`, label: "Casos De Exito" },
    { href: `${homeHref}/blog`, label: "Blog" },
    { href: `${homeHref}/about`, label: "Nuestro equipo" },
];
---

<header class="top-nav">
    <nav class="nav-shell" aria-label="Principal">
        <a href={homeHref} class="brand" aria-label="Ir al inicio">
            <span class="brand-mark" aria-hidden="true">
                <img src="/Logo360x360Icon.png" alt="" class="brand-logo" />
            </span>
            <span class="brand-text">CROBF</span>
        </a>

        <button id="menu-button" class="menu-button" aria-label="Abrir menu" aria-expanded="false" type="button">
            <span></span>
            <span></span>
            <span></span>
        </button>

        <div class="menu-panel" id="menu-panel">
            <div class="menu-links">
                {
                    links.map((item) => (
                        <a href={item.href} class="menu-link">{item.label}</a>
                    ))
                }
            </div>
            <a href={`${homeHref}/contact`} class="cta">Contactanos</a>
        </div>
    </nav>
</header>

<script is:inline>
    const navPanel = document.getElementById("menu-panel");
    const menuButton = document.getElementById("menu-button");

    if (navPanel && menuButton) {
        menuButton.addEventListener("click", () => {
            navPanel.classList.toggle("open");
            const expanded = navPanel.classList.contains("open");
            menuButton.setAttribute("aria-expanded", expanded ? "true" : "false");
        });

        navPanel.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
                navPanel.classList.remove("open");
                menuButton.setAttribute("aria-expanded", "false");
            });
        });
    }
</script>

<style>
    :global(html) {
        scroll-behavior: smooth;
    }

    .top-nav {
        position: sticky;
        top: 0;
        z-index: 40;
        background: #04070f;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .nav-shell {
        width: min(1220px, 100% - 2.6rem);
        margin: 0 auto;
        min-height: 72px;
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        column-gap: 1.1rem;
    }

    .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
        color: #ffffff;
    }

    .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .brand-logo {
        width: 22px;
        height: 22px;
        object-fit: contain;
    }

    .brand-text {
        font-size: 28px;
        line-height: 1;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: #ffffff;
    }

    .menu-panel {
        display: contents;
    }

    .menu-links {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
    }

    .menu-link {
        color: rgba(240, 244, 255, 0.95);
        text-decoration: none;
        font-size: 16px;
        line-height: 1;
        font-weight: 500;
        letter-spacing: -0.01em;
        padding: 0.3rem 0.2rem;
        transition: color 160ms ease;
    }

    .menu-link:hover {
        color: #8ea7ff;
    }

    .cta {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 42px;
        min-width: 150px;
        padding: 0 1.5rem;
        border-radius: 999px;
        text-decoration: none;
        color: #f8f9ff;
        font-size: 16px;
        font-weight: 600;
        background: #4e6ff7;
        transition: background-color 160ms ease;
    }

    .cta:hover {
        background: #5f7efc;
    }

    .menu-button {
        display: none;
        border: none;
        background: transparent;
        padding: 0;
        margin-left: auto;
        cursor: pointer;
    }

    .menu-button span {
        display: block;
        width: 24px;
        height: 2px;
        background: #f4f6ff;
        margin: 5px 0;
    }

    @media (max-width: 1020px) {
        .brand-text {
            font-size: 22px;
        }

        .menu-link {
            font-size: 14px;
        }

        .cta {
            font-size: 14px;
            height: 38px;
            min-width: 122px;
        }
    }

    @media (max-width: 820px) {
        .nav-shell {
            width: min(1220px, 100% - 1.8rem);
            min-height: 74px;
            grid-template-columns: auto auto;
            position: relative;
        }

        .menu-button {
            display: block;
        }

        .menu-panel {
            display: none;
            position: absolute;
            left: 0;
            right: 0;
            top: 100%;
            background: #04070f;
            border: 1px solid rgba(255, 255, 255, 0.14);
            border-top: none;
            border-radius: 0 0 0.8rem 0.8rem;
            padding: 0.8rem 1rem 1rem;
        }

        .menu-panel.open {
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }

        .menu-links {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.55rem;
        }

        .menu-link {
            font-size: 1rem;
            padding: 0.55rem 0;
        }

        .cta {
            width: 100%;
            justify-self: stretch;
            font-size: 1rem;
        }
    }
</style>