---
import { getLangFromUrl } from "../i18n/translate";

const lang = getLangFromUrl(Astro.url);
const homeHref = `/${lang}`;

const links = [
    { href: homeHref, label: "Inicio" },
    { href: `${homeHref}/#casos-exito`, label: "Casos De Exito" },
    { href: `${homeHref}/blog`, label: "Blog" },
    { href: `${homeHref}/about`, label: "Nuestro equipo" },
];
---

<header class="top-nav">
    <nav class="nav-shell" aria-label="Principal">
        <div class="menu-wrap">
            <button
                id="menu-button"
                class="menu-button"
                aria-label="Abrir menu"
                aria-controls="menu-panel"
                aria-expanded="false"
                type="button"
            >
                <span class="menu-icon" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </span>
                <span class="menu-label">Menu</span>
            </button>

            <div class="menu-panel" id="menu-panel" role="dialog" aria-hidden="true">
                <div class="menu-panel-header">
                    <button id="menu-close" class="menu-close" aria-label="Cerrar menu" type="button">
                        <span class="menu-close-icon" aria-hidden="true"></span>
                    </button>
                </div>

                <div class="menu-card">
                    <p class="menu-eyebrow">Navegacion</p>
                    <div class="menu-links">
                        {
                            links.map((item) => (
                                <a href={item.href} class="menu-link">{item.label}</a>
                            ))
                        }
                    </div>

                    <a href={`${homeHref}/contact`} class="menu-contact">Contactanos</a>
                </div>
            </div>
        </div>

        <a href={homeHref} class="brand" aria-label="Ir al inicio">
            <span class="brand-mark" aria-hidden="true">
                <img src="/Logo%20de%20crobf%201.png" alt="" class="brand-logo" />
            </span>
            <span class="brand-text">CROBF</span>
        </a>

        <a href={`${homeHref}/contact`} class="cta">Contactanos</a>
    </nav>
</header>

<script is:inline>
    const navPanel = document.getElementById("menu-panel");
    const menuButton = document.getElementById("menu-button");
    const closeButton = document.getElementById("menu-close");
    const menuWrap = document.querySelector(".menu-wrap");

    if (navPanel && menuButton && menuWrap) {
        const openMenu = () => {
            navPanel.classList.add("open");
            navPanel.setAttribute("aria-hidden", "false");
            menuButton.setAttribute("aria-expanded", "true");
        };

        const closeMenu = () => {
            navPanel.classList.remove("open");
            navPanel.setAttribute("aria-hidden", "true");
            menuButton.setAttribute("aria-expanded", "false");
        };

        menuButton.addEventListener("click", () => {
            const isOpen = navPanel.classList.contains("open");
            if (isOpen) {
                closeMenu();
                return;
            }
            openMenu();
        });

        closeButton?.addEventListener("click", closeMenu);

        navPanel.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
                closeMenu();
            });
        });

        document.addEventListener("click", (event) => {
            if (!(event.target instanceof Node)) return;
            if (!navPanel.classList.contains("open")) return;

            if (!menuWrap.contains(event.target)) {
                closeMenu();
            }
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape") {
                closeMenu();
            }
        });
    }
</script>

<style>
    :global(html) {
        scroll-behavior: smooth;
    }

    .top-nav {
        position: sticky;
        top: 0;
        z-index: 40;
        background: #ffffff;
        border-bottom: 1px solid rgba(24, 33, 58, 0.14);
    }

    .nav-shell {
        width: min(1220px, 100% - 2.6rem);
        margin: 0 auto;
        min-height: 72px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        column-gap: 1.1rem;
        position: relative;
    }

    .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        text-decoration: none;
        color: rgba(16, 25, 49, 0.96);
        justify-self: center;
    }

    .brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .brand-logo {
        width: 22px;
        height: 22px;
        object-fit: contain;
    }

    .brand-text {
        font-size: 28px;
        line-height: 1;
        font-weight: 700;
        letter-spacing: -0.03em;
        color: rgba(16, 25, 49, 0.96);
    }

    .menu-wrap {
        justify-self: start;
        position: relative;
    }

    .cta {
        justify-self: end;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        height: 42px;
        min-width: 150px;
        padding: 0 1.5rem;
        border-radius: 999px;
        text-decoration: none;
        color: #f8f9ff;
        font-size: 16px;
        font-weight: 600;
        background: #4e6ff7;
        transition: background-color 160ms ease;
    }

    .cta:hover {
        background: #5f7efc;
    }

    .menu-links {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0;
    }

    .menu-link {
        color: rgba(18, 28, 52, 0.94);
        text-decoration: none;
        font-size: clamp(1.3rem, 2.8vw, 1.9rem);
        line-height: 1.1;
        font-weight: 500;
        letter-spacing: -0.02em;
        padding: 0.82rem 0;
        border-bottom: 1px solid rgba(41, 57, 95, 0.14);
        transition: color 160ms ease;
    }

    .menu-link:hover {
        color: #314ea9;
    }

    .menu-button {
        display: inline-flex;
        flex-direction: row;
        align-items: center;
        gap: 0.48rem;
        justify-content: center;
        border: 1px solid rgba(27, 42, 77, 0.18);
        background: #ffffff;
        min-width: 92px;
        height: 42px;
        padding: 0 0.8rem;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
        color: rgba(20, 33, 64, 0.92);
        cursor: pointer;
        transition: background-color 160ms ease, border-color 160ms ease, transform 220ms ease;
        position: relative;
        z-index: 2;
    }

    .menu-button:hover {
        background: rgba(60, 92, 198, 0.08);
        border-color: rgba(34, 51, 92, 0.28);
    }

    .menu-icon {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .menu-icon span {
        display: block;
        width: 17px;
        height: 2px;
        border-radius: 999px;
        background: currentColor;
    }

    .menu-label {
        line-height: 1;
        letter-spacing: 0.01em;
    }

    .menu-panel {
        display: block;
        position: absolute;
        left: 0;
        top: calc(100% + 0.55rem);
        width: min(520px, calc(100% - 1.6rem));
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid rgba(23, 39, 72, 0.14);
        border-radius: 1rem;
        box-shadow: 0 16px 40px rgba(11, 22, 48, 0.15);
        z-index: 120;
        overflow: hidden;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateY(-10px) scale(0.9);
        transform-origin: 28px -18px;
        clip-path: circle(8px at 52px -14px);
        transition:
            opacity 240ms ease,
            transform 340ms cubic-bezier(0.16, 1, 0.3, 1),
            clip-path 380ms cubic-bezier(0.16, 1, 0.3, 1),
            visibility 0ms linear 380ms;
    }

    .menu-panel.open {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0) scale(1);
        clip-path: circle(165% at 52px -14px);
        transition:
            opacity 220ms ease,
            transform 340ms cubic-bezier(0.16, 1, 0.3, 1),
            clip-path 400ms cubic-bezier(0.16, 1, 0.3, 1),
            visibility 0ms;
    }

    .menu-button[aria-expanded="true"] {
        transform: translateY(1px);
    }

    .menu-panel-header {
        min-height: 60px;
        display: flex;
        align-items: center;
        padding: 0 1rem;
        border-bottom: 1px solid rgba(28, 43, 78, 0.12);
    }

    .menu-close {
        display: inline-flex;
        align-items: center;
        border: none;
        background: transparent;
        color: rgba(17, 30, 58, 0.96);
        cursor: pointer;
        padding: 0;
    }

    .menu-close-icon {
        width: 20px;
        height: 20px;
        position: relative;
    }

    .menu-close-icon::before,
    .menu-close-icon::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 0;
        width: 100%;
        height: 2px;
        border-radius: 999px;
        background: currentColor;
    }

    .menu-close-icon::before {
        transform: translateY(-50%) rotate(45deg);
    }

    .menu-close-icon::after {
        transform: translateY(-50%) rotate(-45deg);
    }

    .menu-card {
        width: calc(100% - 1.1rem);
        margin: 0.55rem auto;
        padding: 1.1rem 1rem 1.2rem;
        border-radius: 0.9rem;
        background: linear-gradient(165deg, #ffffff 0%, #f2f6ff 100%);
        border: 1px solid rgba(31, 49, 89, 0.12);
    }

    .menu-eyebrow {
        margin: 0 0 1rem;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        font-size: 0.86rem;
        color: rgba(44, 62, 103, 0.7);
    }

    .menu-contact {
        display: inline-flex;
        margin-top: 2rem;
        padding: 0.35rem 0.6rem;
        border-radius: 0.35rem;
        text-decoration: none;
        font-size: 0.88rem;
        color: rgba(20, 33, 64, 0.92);
        background: rgba(46, 80, 184, 0.12);
    }

    :global(html.dark) .top-nav {
        background: #04070f;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    :global(html.dark) .brand,
    :global(html.dark) .brand-text {
        color: #ffffff;
    }

    :global(html.dark) .menu-button {
        background: rgba(7, 12, 26, 0.8);
        border-color: rgba(230, 238, 255, 0.24);
        color: #f4f6ff;
    }

    :global(html.dark) .menu-button:hover {
        background: rgba(106, 134, 235, 0.2);
        border-color: rgba(230, 238, 255, 0.38);
    }

    :global(html.dark) .menu-panel {
        background: linear-gradient(180deg, #171519 0%, #141216 100%);
        border: 1px solid rgba(255, 255, 255, 0.12);
        box-shadow: 0 16px 40px rgba(5, 7, 14, 0.5);
    }

    :global(html.dark) .menu-panel-header {
        border-bottom: 1px solid rgba(244, 247, 255, 0.12);
    }

    :global(html.dark) .menu-close {
        color: rgba(248, 250, 255, 0.96);
    }

    :global(html.dark) .menu-card {
        background: linear-gradient(165deg, #252227 0%, #211f24 100%);
        border: 1px solid rgba(255, 255, 255, 0.06);
    }

    :global(html.dark) .menu-eyebrow {
        color: rgba(206, 212, 232, 0.72);
    }

    :global(html.dark) .menu-link {
        color: rgba(242, 244, 250, 0.95);
        border-bottom: 1px solid rgba(222, 226, 238, 0.12);
    }

    :global(html.dark) .menu-link:hover {
        color: #ffffff;
    }

    :global(html.dark) .menu-contact {
        color: rgba(245, 248, 255, 0.9);
        background: rgba(255, 255, 255, 0.1);
    }

    @media (max-width: 1020px) {
        .brand-text {
            font-size: 22px;
        }

        .cta {
            font-size: 14px;
            height: 38px;
            min-width: 122px;
        }
    }

    @media (max-width: 820px) {
        .nav-shell {
            width: min(1220px, 100% - 1.8rem);
            min-height: 74px;
            grid-template-columns: 1fr auto 1fr;
            column-gap: 0.6rem;
        }

        .brand-text {
            font-size: clamp(18px, 5.2vw, 22px);
        }

        .cta {
            display: none;
        }

        .menu-panel {
            left: 0;
            width: min(420px, calc(100% - 1.6rem));
            transform-origin: 26px -16px;
            clip-path: circle(8px at 50px -12px);
        }

        .menu-panel.open {
            clip-path: circle(175% at 50px -12px);
        }

        .menu-card {
            width: calc(100% - 1rem);
            margin: 0.5rem auto;
            border-radius: 0.85rem;
            padding: 0.95rem;
        }

        .menu-link {
            font-size: clamp(1.18rem, 6.2vw, 1.5rem);
        }
    }

    @media (max-width: 420px) {
        .nav-shell {
            width: calc(100% - 1rem);
            min-height: 68px;
        }

        .menu-button {
            min-width: 84px;
            height: 38px;
            padding: 0 0.65rem;
            font-size: 13px;
        }

        .brand-logo {
            width: 19px;
            height: 19px;
        }
    }
</style>