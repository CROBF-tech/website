---
const { title, description } = Astro.props;
---

<div class="service-card">
    <div class="service-card__icon-and-text">
        <!-- Ícono a la izquierda -->
        <div class="service-card__icon">
            <slot />
        </div>
        <!-- Título y descripción a la derecha -->
        <div class="service-card__text">
            <h2>{title}</h2>
            <p>{description}</p>
        </div>
    </div>
</div>

<style>
    /* Contenedor principal de la card */
    .service-card {
        border: 1px solid #333;
        background-color: #ffffff;
        padding: 0.75rem; /* Reducido de 1rem */
        border-radius: 0.5rem; /* ~ rounded-lg */
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    /* Efecto de elevación al pasar el mouse */
    .service-card:hover {
        transform: translateY(-5px);
    }

    /* Estructura horizontal: icono y texto */
    .service-card__icon-and-text {
        display: flex;
        align-items: flex-start; /* Icono y primera línea de texto alineados arriba */
        gap: 0.65rem; /* Reducido de 1rem */
        flex-direction: column;
    }

    /* Icono (SVG usa fill="currentColor") */
    .service-card__icon {
        color: var(--black); /* Heredado por el SVG */
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Texto */
    .service-card__text {
        display: flex;
        flex-direction: column;
        gap: 0.2rem; /* Reducido de 0.25rem */
    }

    /* Título */
    .service-card__text h2 {
        font-size: 1rem; /* Reducido de 1.2rem */
        font-weight: bold;
        color: var(--black);
        line-height: 1.2; /* Reducido de 1.25 */
    }

    /* Descripción */
    .service-card__text p {
        font-size: 0.875rem; /* Reducido de 1rem */
        color: var(--black);
        line-height: 1.2; /* Reducido de 1.25 */
    }

    html.dark .service-card {
        background-color: #39445b;
        border: 1px solid #555555;
    }

    html.dark .service-card__icon,
    html.dark .service-card h2 {
        color: #ffffff;
    }

    html.dark .service-card p {
        color: #cccccc;
    }

    @media (max-width: 768px) {
        .service-card {
            padding: 0.65rem; /* Reducido de 0.85rem */
        }

        .service-card__text h2 {
            font-size: 0.95rem; /* Reducido de 1.05rem */
        }

        .service-card__text p {
            font-size: 0.8rem; /* Reducido de 0.9rem */
        }
    }

    @media (max-width: 480px) {
        .service-card__icon-and-text {
            gap: 0.6rem; /* Reducido de 0.75rem */
        }
    }
</style>
