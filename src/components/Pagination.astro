---
import IconChevronFirst from "./svgs/IconChevronFirst.astro";
import IconChevronLeft from "./svgs/IconChevronLeft.astro";
import IconChevronRight from "./svgs/IconChevronRight.astro";
import IconChevronLast from "./svgs/IconChevronLast.astro";

interface Props {
    total: number;
    current: number;
    lang?: "es" | "en";
    baseHref?: string;
    showFirstLast?: boolean;
}

const { total, current, lang = "es", baseHref, showFirstLast = true } = Astro.props;

const labels = {
    es: { first: "Primera", last: "Última", prev: "Anterior", next: "Siguiente", page: "Página" },
    en: { first: "First", last: "Last", prev: "Previous", next: "Next", page: "Page" },
};
const t = labels[lang];

const buildHref = (page: number): string => {
    const params = new URLSearchParams();
    if (page > 1) params.set("page", String(page));
    const qs = params.toString();
    const base = baseHref ?? Astro.url.pathname;
    return qs ? `${base}?${qs}` : base;
};

const neighbours = 1;
const pages: (number | "…")[] = [];
const push = (value: number | "…") => {
    if (pages.length === 0 || pages[pages.length - 1] !== value) pages.push(value);
};

if (showFirstLast) push(1);
const start = Math.max(showFirstLast ? 2 : 1, current - neighbours);
const end = Math.min(showFirstLast ? total - 1 : total, current + neighbours);
if (start > (showFirstLast ? 2 : 1)) push("…");
for (let p = start; p <= end; p++) push(p);
if (end < (showFirstLast ? total - 1 : total)) push("…");
if (showFirstLast && total > 1) push(total);

const isFirst = current <= 1;
const isLast = current >= total;
---

<nav class="pagination" aria-label={t.page}>
    {
        showFirstLast && (
            <a
                href={buildHref(1)}
                class:list={["pagination-link pagination-link--edge", { "is-disabled": isFirst }]}
                aria-label={t.first}
                aria-disabled={isFirst ? "true" : undefined}
                tabindex={isFirst ? -1 : undefined}
            >
                <IconChevronFirst />
            </a>
        )
    }

    <a
        href={buildHref(current - 1)}
        class:list={["pagination-link pagination-link--edge", { "is-disabled": isFirst }]}
        aria-label={t.prev}
        aria-disabled={isFirst ? "true" : undefined}
        tabindex={isFirst ? -1 : undefined}
    >
        <IconChevronLeft />
    </a>

    <div class="pagination-numbers" role="list">
        {
            pages.map((entry) =>
                entry === "…" ? (
                    <span class="pagination-ellipsis" aria-hidden="true">…</span>
                ) : (
                    <a
                        href={buildHref(entry)}
                        class:list={["pagination-link", { active: entry === current }]}
                        aria-label={`${t.page} ${entry}`}
                        aria-current={entry === current ? "page" : undefined}
                    >
                        {entry}
                    </a>
                )
            )
        }
    </div>

    <a
        href={buildHref(current + 1)}
        class:list={["pagination-link pagination-link--edge", { "is-disabled": isLast }]}
        aria-label={t.next}
        aria-disabled={isLast ? "true" : undefined}
        tabindex={isLast ? -1 : undefined}
    >
        <IconChevronRight />
    </a>

    {
        showFirstLast && (
            <a
                href={buildHref(total)}
                class:list={["pagination-link pagination-link--edge", { "is-disabled": isLast }]}
                aria-label={t.last}
                aria-disabled={isLast ? "true" : undefined}
                tabindex={isLast ? -1 : undefined}
            >
                <IconChevronLast />
            </a>
        )
    }
</nav>

<style>
    .pagination {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin: 2.5rem 0 0;
    }

    .pagination-numbers {
        display: flex;
        gap: 0.4rem;
        align-items: center;
    }

    .pagination-link {
        min-width: 2.25rem;
        height: 2.25rem;
        padding: 0 0.65rem;
        border: 1px solid rgba(95, 114, 166, 0.25);
        border-radius: 0.6rem;
        background: transparent;
        color: rgba(23, 30, 48, 0.85);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: 600;
        transition: background-color 180ms ease, color 180ms ease, border-color 180ms ease, transform 180ms ease;
    }

    .pagination-link:hover {
        background: rgba(73, 109, 244, 0.08);
        border-color: rgba(73, 109, 244, 0.45);
        color: rgba(20, 30, 58, 0.95);
    }

    .pagination-link.active {
        background: linear-gradient(120deg, #1f34f3, #4c6aff);
        color: #f6f8ff;
        border-color: transparent;
        box-shadow: 0 8px 22px rgba(41, 76, 255, 0.28);
    }

    .pagination-link--edge {
        padding: 0 0.55rem;
    }

    .pagination-link.is-disabled {
        opacity: 0.4;
        pointer-events: none;
    }

    .pagination-ellipsis {
        min-width: 1.5rem;
        text-align: center;
        color: rgba(23, 30, 48, 0.55);
        font-weight: 600;
        user-select: none;
    }

    :global(html.dark) .pagination-link {
        color: rgba(229, 236, 255, 0.85);
        border-color: rgba(160, 178, 235, 0.22);
    }

    :global(html.dark) .pagination-link:hover {
        background: rgba(95, 126, 252, 0.18);
        color: #ffffff;
    }

    :global(html.dark) .pagination-ellipsis {
        color: rgba(229, 236, 255, 0.55);
    }

    @media (max-width: 520px) {
        .pagination {
            gap: 0.3rem;
        }

        .pagination-link {
            min-width: 2rem;
            height: 2rem;
            font-size: 0.78rem;
        }

        .pagination-numbers {
            gap: 0.25rem;
        }
    }
</style>
