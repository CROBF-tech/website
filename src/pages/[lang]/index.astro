---
import Layout from "../../layouts/Layout.astro";
import YouCanScroll from "../../components/YouCanScroll.astro";
import { SITE_DESCRIPTION } from "../../consts";
import { getLangFromUrl } from "../../i18n/translate";

const lang = getLangFromUrl(Astro.url);

const copy =
    lang === "en"
        ? {
              badge: "Technology studio",
              heroTitle: "Need an app, website, or system for your company?",
              heroText: "We build digital products with strategy, design, and engineering to help your business scale.",
              heroPrimary: "Start a project",
              heroSecondary: "View services",
              heroMetaA: "Consulting and Product",
              heroMetaB: "In-house software team",
              heroGapTitle: "",
              servicesTitle: "What can we build together?",
              servicesSubtitle: "Examples",
              processTitle: "How it works",
              processSubtitle: "Work process",
              portfolioTitle: "Your industry could be next",
              portfolioSubtitle: "Success stories",
              withUsSubtitle: "Solutions Squad",
              teamTitle: "Our team",
              teamText: "Product designers, engineers, and growth specialists focused on real outcomes.",
              teamAction: "View founders",
              ctaText: "Join the future of autonomous software development.",
              ctaAction: "Schedule a meeting",
              endTitle: "Ready to digitize your business?",
              endPrimary: "Let's start",
                            endSecondary: "Learn more about us",
          }
        : {
              badge: "Estudio de tecnologia",
              heroTitle: "Necesitas una app, web o sistema para tu empresa?",
              heroText: "Construimos productos digitales con estrategia, diseno y desarrollo para escalar tu negocio.",
              heroPrimary: "Iniciar proyecto",
              heroSecondary: "Ver servicios",
              heroMetaA: "Consultoria y producto",
              heroMetaB: "Equipo interno de software",
              heroGapTitle: "",
              servicesTitle: "Que podemos crear juntos?",
              servicesSubtitle: "Ejemplos",
              processTitle: "Como funciona",
              processSubtitle: "Proceso de trabajo",
              portfolioTitle: "Ya lo hicimos. Tu industria puede ser la proxima",
              portfolioSubtitle: "Casos reales",
              withUsSubtitle: "Solutions Squad",
              teamTitle: "Nuestro equipo",
              teamText: "Disenadores, developers y especialistas en crecimiento enfocados en resultados reales.",
              teamAction: "Ver founders",
              ctaText: "Sumate al futuro del desarrollo de software autonomo.",
              ctaAction: "Agenda una reunion",
              endTitle: "Listo para digitalizar tu negocio?",
              endPrimary: "Comencemos",
              endSecondary: "Conoce mas sobre nosotros",
          };

const serviceItems =
    lang === "en"
        ? [
              {
                  icon: "app",
                  title: "App and web systems",
                  text: "Order, stock, shift, and customer management. Built around your workflow.",
              },
              {
                  icon: "dashboard",
                  title: "Dashboards and reports",
                  text: "Clear real-time business data for better decisions.",
              },
              {
                  icon: "automation",
                  title: "Automation",
                  text: "Remove repetitive tasks so your team can focus on what matters.",
              },
              {
                  icon: "commerce",
                  title: "E-commerce",
                  text: "Online stores integrated with payment, invoicing, logistics, and stock.",
              },
              {
                  icon: "ai",
                  title: "Artificial intelligence",
                  text: "Chatbots, demand prediction, and data analysis with AI for your business.",
              },
              {
                  icon: "integrations",
                  title: "Integrations",
                  text: "We connect tools like SAP, Tango, MercadoPago, WhatsApp, and your current stack.",
              },
          ]
        : [
              {
                  icon: "app",
                  title: "App y sistemas web",
                  text: "Gestion de pedidos, stock, turnos y clientes. Lo que necesites, a medida.",
              },
              {
                  icon: "dashboard",
                  title: "Dashboards e informes",
                  text: "Datos de tu negocio claros y en tiempo real para tomar mejores decisiones.",
              },
              {
                  icon: "automation",
                  title: "Automatizacion",
                  text: "Elimina tareas manuales y repetitivas para que tu equipo se enfoque en lo importante.",
              },
              {
                  icon: "commerce",
                  title: "E-commerce",
                  text: "Tiendas online integradas con medios de pago, facturacion, logistica y stock.",
              },
              {
                  icon: "ai",
                  title: "Inteligencia artificial",
                  text: "Chatbots, prediccion de demanda y analisis de datos con IA aplicada a tu negocio.",
              },
              {
                  icon: "integrations",
                  title: "Integraciones",
                  text: "Conectamos SAP, Tango, MercadoPago, WhatsApp y lo que ya uses hoy.",
              },
          ];

const steps = [
    {
        number: "01",
        icon: "discovery",
        title: "Descubrimiento y Analisis",
        text: "Comenzamos entendiendo los objetivos de tu negocio y los requerimientos tecnicos. Definimos juntos el alcance del proyecto y te enviamos una cotizacion personalizada.",
    },
    {
        number: "02",
        icon: "development",
        title: "Desarrollo",
        text: "Desarrollamos tu solucion a medida utilizando tecnologias modernas y practicas agiles. Recibis actualizaciones de progreso en cada sprint.",
    },
    {
        number: "03",
        icon: "testing",
        title: "Pruebas e implementacion",
        text: "Antes del lanzamiento, se validan la funcionalidad, el rendimiento y la usabilidad. Aseguramos una implementacion fluida y sin interrupciones.",
    },
    {
        number: "04",
        icon: "support",
        title: "Soporte continuo",
        text: "Despues de la entrega, brindamos mantenimiento, actualizaciones y optimizacion continua. Tu sistema se mantiene estable y preparado para crecer junto a tu negocio.",
    },
];

const projects = [
    {
        image: "/projects/hexadevs.png",
        title: "Hexadevs",
        text: "Sitio institucional con foco en conversion.",
    },
    {
        image: "/projects/todo-app.svg",
        title: "Taskflow",
        text: "Sistema de tareas y productividad para equipos.",
    },
    {
        image: "/projects/flashcards.svg",
        title: "Learning Hub",
        text: "Plataforma educativa para aprendizaje dinamico.",
    },
    {
        image: "/projects/bunny-js.svg",
        title: "Bunny JS",
        text: "Web app ligera orientada a performance y conversion.",
    },
    {
        image: "/projects/animal.svg",
        title: "Animal UI",
        text: "Landing visual con identidad de marca y narrativa clara.",
    },
];

---

<Layout title="CROBF" description={SITE_DESCRIPTION}>
    <script is:inline type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
    <main class="home">
        <section class="hero" id="inicio">
            <div class="hero-copy" data-reveal="left" style="--reveal-delay: 0ms;">
                <p class="eyebrow">{copy.badge}</p>
                <h1>{copy.heroTitle}</h1>
                <p class="subtitle">{copy.heroText}</p>
                <ul class="hero-meta">
                    <li>{copy.heroMetaA}</li>
                    <li>{copy.heroMetaB}</li>
                </ul>
                <div class="actions">
                    <a href={`/${lang}/contact`} class="btn btn-primary">{copy.heroPrimary}</a>
                    <a href="#services" class="btn btn-ghost">{copy.heroSecondary}</a>
                </div>
            </div>
            <div class="hero-visual" aria-hidden="true" data-reveal="right" style="--reveal-delay: 80ms;">
                <model-viewer
                    class="hero-phone"
                    src="/models/iphone_17_pro_max.glb"
                    alt="Phone 3D model"
                    auto-rotate
                    rotation-per-second="10deg"
                    interaction-prompt="none"
                    disable-zoom
                    shadow-intensity="0.9"
                    exposure="1.1"
                ></model-viewer>
            </div>
        </section>

        <section class="services" id="services">
            <p class="eyebrow" data-reveal style="--reveal-delay: 0ms;">{copy.servicesSubtitle}</p>
            <h2 data-reveal style="--reveal-delay: 50ms;">{copy.servicesTitle}</h2>
            <div class="services-grid">
                {
                    serviceItems.map((service, index) => (
                        <article
                            class="service-card tilt-card"
                            data-reveal
                            data-reveal-card
                            style={`--reveal-delay: 0ms; --reveal-opacity-duration: 3800ms; --reveal-transform-duration: 5600ms; --reveal-y: 38px;`}
                        >
                            <span class="service-icon tilt-layer" data-depth="18" aria-hidden="true">
                                {
                                    service.icon === "app" && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="4" y="3.5" width="16" height="17" rx="2.5"></rect>
                                            <line x1="9" y1="6.8" x2="15" y2="6.8"></line>
                                            <circle cx="12" cy="16.2" r="1.1"></circle>
                                        </svg>
                                    )
                                }
                                {
                                    service.icon === "dashboard" && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                            <line x1="5" y1="19" x2="19" y2="19"></line>
                                            <rect x="6" y="11" width="2.8" height="6"></rect>
                                            <rect x="10.6" y="8" width="2.8" height="9"></rect>
                                            <rect x="15.2" y="6" width="2.8" height="11"></rect>
                                        </svg>
                                    )
                                }
                                {
                                    service.icon === "automation" && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="8" cy="8" r="2"></circle>
                                            <circle cx="16" cy="16" r="2"></circle>
                                            <path d="M10 8h4a2 2 0 0 1 2 2v4"></path>
                                            <path d="M14 16h-4a2 2 0 0 1-2-2v-4"></path>
                                        </svg>
                                    )
                                }
                                {
                                    service.icon === "commerce" && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M4.5 6.5h2l1.2 8.2h9.1l1.2-6.3H8.2"></path>
                                            <circle cx="10" cy="18.2" r="1.3"></circle>
                                            <circle cx="15.8" cy="18.2" r="1.3"></circle>
                                        </svg>
                                    )
                                }
                                {
                                    service.icon === "ai" && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                            <circle cx="12" cy="12" r="2.2"></circle>
                                            <path d="M12 4.5v3"></path>
                                            <path d="M12 16.5v3"></path>
                                            <path d="M4.5 12h3"></path>
                                            <path d="M16.5 12h3"></path>
                                            <path d="M6.8 6.8l2.1 2.1"></path>
                                            <path d="M15.1 15.1l2.1 2.1"></path>
                                        </svg>
                                    )
                                }
                                {
                                    service.icon === "integrations" && (
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="3.8" y="9.5" width="5" height="5" rx="1.2"></rect>
                                            <rect x="15.2" y="3.8" width="5" height="5" rx="1.2"></rect>
                                            <rect x="15.2" y="15.2" width="5" height="5" rx="1.2"></rect>
                                            <path d="M8.8 12h6.2"></path>
                                            <path d="M17.7 8.8v6.4"></path>
                                        </svg>
                                    )
                                }
                            </span>
                            <h3 class="tilt-layer" data-depth="24">{service.title}</h3>
                            <p class="tilt-layer" data-depth="14">{service.text}</p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="process">
            <h2 data-reveal style="--reveal-delay: 40ms;">{copy.processTitle}</h2>
            <div class="process-grid">
                {
                    steps.map((step, index) => (
                        <article class="step-card" style={`--stage-delay: ${index * 1800}ms;`}>
                            <div class="step-dot" aria-hidden="true">
                                {step.icon === "discovery" && (
                                    <svg class="step-icon icon-discovery" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="4.6"></circle>
                                        <line x1="14.6" y1="14.6" x2="18.2" y2="18.2"></line>
                                        <line x1="11" y1="8.5" x2="11" y2="13.5"></line>
                                        <line x1="8.5" y1="11" x2="13.5" y2="11"></line>
                                    </svg>
                                )}
                                {step.icon === "development" && (
                                    <svg class="step-icon icon-development" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline class="dev-left" points="8.2 8.2 4.7 12 8.2 15.8"></polyline>
                                        <polyline class="dev-right" points="15.8 8.2 19.3 12 15.8 15.8"></polyline>
                                        <line class="dev-slash" x1="13.2" y1="6.8" x2="10.8" y2="17.2"></line>
                                    </svg>
                                )}
                                {step.icon === "testing" && (
                                    <svg class="step-icon icon-testing" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="4.5" y="5.8" width="15" height="12.8" rx="2"></rect>
                                        <polyline class="check-mark" points="8 12.2 10.7 14.9 16 9.6"></polyline>
                                    </svg>
                                )}
                                {step.icon === "support" && (
                                    <svg class="step-icon icon-support" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4.8 12a7.2 7.2 0 0 1 14.4 0"></path>
                                        <rect x="4.6" y="11.9" width="2.8" height="5.2" rx="1"></rect>
                                        <rect x="16.6" y="11.9" width="2.8" height="5.2" rx="1"></rect>
                                        <path d="M19.4 17.1a3 3 0 0 1-3 3H12"></path>
                                        <rect x="10.5" y="19" width="3" height="1.8" rx="0.8"></rect>
                                    </svg>
                                )}
                            </div>
                            <p class="step-number">{step.number}</p>
                            <h3>{step.title}</h3>
                            <p>{step.text}</p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="portfolio" id="casos-exito">
            <p class="eyebrow" data-reveal>{copy.portfolioSubtitle}</p>
            <h2 data-reveal style="--reveal-delay: 40ms;">{copy.portfolioTitle}</h2>
            <div class="portfolio-row">
                {
                    projects.map((project, index) => (
                        <article class="project-card" data-reveal style={`--reveal-delay: ${70 + index * 45}ms;`}>
                            <img src={project.image} alt={project.title} loading="lazy" />
                            <h3>{project.title}</h3>
                            <p>{project.text}</p>
                        </article>
                    ))
                }
            </div>
        </section>

        <YouCanScroll />

        <section class="team" id="about-us">
            <div class="team-copy" data-reveal>
                <p class="eyebrow">{copy.withUsSubtitle}</p>
                <h2>{copy.teamTitle}</h2>
                <p>{copy.teamText}</p>
                <a href={`/${lang}/about`} class="btn btn-primary">{copy.teamAction}</a>
            </div>
        </section>

        <section class="floating-cta" data-reveal>
            <p>{copy.ctaText}</p>
            <a href={`/${lang}/contact`} class="btn btn-primary">{copy.ctaAction}</a>
        </section>

        <section class="end-cta" id="contacto">
            <h2 data-reveal>{copy.endTitle}</h2>
            <div class="actions">
                <a href={`/${lang}/contact`} class="btn btn-ghost" data-reveal style="--reveal-delay: 40ms;">{copy.endPrimary}</a>
                <a href={`/${lang}/about`} class="btn btn-primary" data-reveal style="--reveal-delay: 70ms;">{copy.endSecondary}</a>
            </div>
        </section>

        <script is:inline>
            const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

            if (!reduceMotion) {
                document.querySelectorAll(".tilt-card").forEach((card) => {
                    const layers = card.querySelectorAll(".tilt-layer");
                    const maxRotate = 7;

                    const reset = () => {
                        card.style.transform = "perspective(900px) rotateX(0deg) rotateY(0deg) translateY(0px)";
                        layers.forEach((layer) => {
                            const depth = Number(layer.getAttribute("data-depth") || 0);
                            layer.style.transform = `translateZ(${depth}px)`;
                        });
                    };

                    reset();

                    card.addEventListener("mousemove", (event) => {
                        const rect = card.getBoundingClientRect();
                        const px = (event.clientX - rect.left) / rect.width - 0.5;
                        const py = (event.clientY - rect.top) / rect.height - 0.5;

                        const ry = px * maxRotate * 2;
                        const rx = -py * maxRotate * 2;

                        card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;

                        layers.forEach((layer) => {
                            const depth = Number(layer.getAttribute("data-depth") || 0);
                            const lx = -px * depth * 0.5;
                            const ly = -py * depth * 0.5;
                            layer.style.transform = `translate3d(${lx}px, ${ly}px, ${depth}px)`;
                        });
                    });

                    card.addEventListener("mouseleave", reset);
                    card.addEventListener("blur", reset, true);
                });
            }

            const revealTargets = document.querySelectorAll("[data-reveal]:not([data-reveal-card])");
            const revealCards = document.querySelectorAll("[data-reveal-card]");
            const processSection = document.querySelector(".process");
            const servicesSection = document.querySelector(".services");

            if (reduceMotion) {
                revealTargets.forEach((target) => target.classList.add("is-visible"));
                revealCards.forEach((target) => target.classList.add("is-visible"));
                if (processSection instanceof HTMLElement) {
                    processSection.classList.add("is-line-active");
                }
            } else {
                const revealObserver = new IntersectionObserver(
                    (entries, observer) => {
                        entries.forEach((entry) => {
                            if (!entry.isIntersecting) return;
                            entry.target.classList.add("is-visible");
                            observer.unobserve(entry.target);
                        });
                    },
                    {
                        threshold: 0.05,
                        rootMargin: "0px 0px -1% 0px",
                    }
                );

                revealTargets.forEach((target) => revealObserver.observe(target));

                if (servicesSection instanceof HTMLElement && revealCards.length) {
                    const servicesCardsObserver = new IntersectionObserver(
                        (entries, observer) => {
                            entries.forEach((entry) => {
                                if (!entry.isIntersecting) return;
                                revealCards.forEach((card, index) => {
                                    window.setTimeout(() => {
                                        card.classList.add("is-visible");
                                    }, index * 900);
                                });
                                observer.unobserve(servicesSection);
                            });
                        },
                        {
                            threshold: 0.28,
                            rootMargin: "0px 0px -6% 0px",
                        }
                    );

                    servicesCardsObserver.observe(servicesSection);
                }

                if (processSection instanceof HTMLElement) {
                    const processObserver = new IntersectionObserver(
                        (entries, observer) => {
                            entries.forEach((entry) => {
                                if (!entry.isIntersecting) return;
                                processSection.classList.add("is-line-active");
                                observer.unobserve(processSection);
                            });
                        },
                        {
                            threshold: 0.38,
                            rootMargin: "0px 0px -8% 0px",
                        }
                    );

                    processObserver.observe(processSection);
                }
            }
        </script>
    </main>
</Layout>

<style>
    .home {
        width: min(1120px, calc(100% - 2.2rem));
        padding: 1.2rem 0 5rem;
        display: grid;
        gap: 5.4rem;
    }

    [data-reveal] {
        opacity: 0;
        transform: translate3d(0, var(--reveal-y, 22px), 0) scale(0.998);
        filter: none;
        transition:
            opacity var(--reveal-opacity-duration, 1450ms) cubic-bezier(0.16, 1, 0.3, 1),
            transform var(--reveal-transform-duration, 2100ms) cubic-bezier(0.16, 1, 0.3, 1),
            filter var(--reveal-opacity-duration, 1450ms) cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: var(--reveal-delay, 0ms);
        will-change: opacity, transform, filter;
    }

    [data-reveal="left"] {
        transform: translate3d(-14px, 6px, 0) scale(0.998);
    }

    [data-reveal="right"] {
        transform: translate3d(14px, 6px, 0) scale(0.998);
    }

    [data-reveal].is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
        filter: blur(0);
    }

    :global(body) {
        overflow-x: hidden;
    }

    .eyebrow {
        margin: 0 0 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        color: rgba(23, 30, 48, 0.72);
    }

    .hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
        align-items: center;
        min-height: 58svh;
        padding-top: 1.4rem;
    }

    .hero-phone {
        position: relative;
        z-index: 3;
        width: clamp(230px, 33vw, 340px);
        height: clamp(390px, 54vw, 560px);
        flex: 0 0 auto;
        background: transparent;
        background-color: transparent;
        --poster-color: transparent;
        filter: drop-shadow(0 24px 36px rgba(4, 12, 34, 0.5));
    }

    h1 {
        font-size: clamp(2rem, 4.6vw, 4.2rem);
        line-height: 1.02;
        margin: 0;
        max-width: 14ch;
    }

    h2 {
        font-size: clamp(1.7rem, 3vw, 2.8rem);
        margin: 0;
        max-width: 20ch;
        line-height: 1.1;
    }

    .subtitle {
        color: rgba(23, 30, 48, 0.78);
        max-width: 52ch;
        margin: 1rem 0 0;
    }

    .hero-meta {
        margin: 0.95rem 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.2rem;
        font-size: 0.72rem;
        color: rgba(31, 42, 72, 0.72);
    }

    .hero-meta li::before {
        content: "+ ";
        color: #4d6eff;
        font-weight: 700;
    }

    .actions {
        margin-top: 1.8rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
    }

    .btn {
        padding: 0.72rem 1.2rem;
        border-radius: 999px;
        font-size: 0.86rem;
        letter-spacing: 0.02em;
        text-decoration: none;
        border: 1px solid transparent;
        transition: transform 140ms ease, box-shadow 140ms ease;
    }

    .btn:hover {
        transform: translateY(-1px);
    }

    .btn-primary {
        background: linear-gradient(120deg, #1f34f3, #4c6aff);
        color: #f6f8ff;
        box-shadow: 0 10px 30px rgba(41, 76, 255, 0.25);
    }

    .btn-ghost {
        border-color: rgba(41, 76, 255, 0.4);
        color: #263575;
        background: rgba(255, 255, 255, 0.68);
    }

    .hero-visual {
        position: relative;
        min-height: 520px;
        display: grid;
        place-items: center;
        border-radius: 1.35rem;
        overflow: visible;
        border: none;
        background: transparent;
        box-shadow: none;
    }

    .hero-visual::before {
        content: none;
    }

    .services-grid {
        margin-top: 1.6rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.55rem;
