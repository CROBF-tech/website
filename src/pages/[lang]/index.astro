---
import Layout from "../../layouts/Layout.astro";
import YouCanScroll from "../../components/YouCanScroll.astro";
import Carousel3D from "../../components/Carousel3D.astro";
import { BentoGrid } from "../../components/ui/bento-grid";
import { SITE_DESCRIPTION } from "../../consts";
import { getLangFromUrl } from "../../i18n/translate";

const lang = getLangFromUrl(Astro.url);

const copy =
    lang === "en"
        ? {
              badge: "Technology studio",
              heroTitle: "We create solutions We build software",
              heroTitleLine1: "We create solutions",
              heroTitleLine2: "We build software",
              heroText: "We build digital products with strategy, design, and engineering to help your business scale.",
              heroPrimary: "Start a project",
              heroSecondary: "View services",
              heroMetaA: "Consulting and Product",
              heroMetaB: "In-house software team",
              heroGapTitle: "",
              servicesTitle: "What can we build together?",
              servicesSubtitle: "Examples",
              processTitle: "How it works",
              processSubtitle: "Work process",
              portfolioTitle: "Your industry could be next",
              portfolioSubtitle: "Success stories",
              withUsSubtitle: "Solutions Squad",
              teamTitle: "Our team",
              teamText: "Product designers, engineers, and growth specialists focused on real outcomes.",
              teamAction: "View founders",
              ctaText: "Join the future of autonomous software development.",
              ctaAction: "Schedule a meeting",
              endTitle: "Ready to digitize your business?",
              endPrimary: "Let's start",
                            endSecondary: "Learn more about us",
          }
        : {
              badge: "Estudio de tecnología",
              heroTitle: "La mejor forma de Creando sistemas",
              heroTitleLine1: "La mejor forma de",
              heroTitleLine2: "Creando sistemas",
              heroText: "Somos expertos en desarrollo de software y diseño de experiencias digitales. Creamos todo tipo de aplicaciones con código propio y soluciones a medida.",
              heroPrimary: "Completar formulario",
              heroSecondary: "Whatsapp directo",
              heroMetaA: "",
              heroMetaB: "",
              heroGapTitle: "",
              servicesTitle: "Que podemos crear juntos?",
              servicesSubtitle: "Ejemplos",
              processTitle: "Como funciona",
              processSubtitle: "Proceso de trabajo",
              portfolioTitle: "Ya lo hicimos. Tu industria puede ser la proxima",
              portfolioSubtitle: "Casos reales",
              withUsSubtitle: "Solutions Squad",
              teamTitle: "Nuestro equipo",
              teamText: "Disenadores, developers y especialistas en crecimiento enfocados en resultados reales.",
              teamAction: "Ver founders",
              ctaText: "Sumate al futuro del desarrollo de software autonomo.",
              ctaAction: "Agenda una reunion",
              endTitle: "Listo para digitalizar tu negocio?",
              endPrimary: "Comencemos",
              endSecondary: "Conoce mas sobre nosotros",
          };

const serviceItems =
    lang === "en"
        ? [
              {
                  icon: "app",
                  title: "App and web systems",
                  text: "Order, stock, shift, and customer management. Built around your workflow.",
              },
              {
                  icon: "dashboard",
                  title: "Dashboards and reports",
                  text: "Clear real-time business data for better decisions.",
              },
              {
                  icon: "automation",
                  title: "Automation",
                  text: "Remove repetitive tasks so your team can focus on what matters.",
              },
              {
                  icon: "commerce",
                  title: "E-commerce",
                  text: "Online stores integrated with payment, invoicing, logistics, and stock.",
              },
              {
                  icon: "ai",
                  title: "Artificial intelligence",
                  text: "Chatbots, demand prediction, and data analysis with AI for your business.",
              },
              {
                  icon: "integrations",
                  title: "Integrations",
                  text: "We connect tools like SAP, Tango, MercadoPago, WhatsApp, and your current stack.",
              },
          ]
        : [
              {
                  icon: "app",
                  title: "App y sistemas web",
                  text: "Gestion de pedidos, stock, turnos y clientes. Lo que necesites, a medida.",
              },
              {
                  icon: "dashboard",
                  title: "Dashboards e informes",
                  text: "Datos de tu negocio claros y en tiempo real para tomar mejores decisiones.",
              },
              {
                  icon: "automation",
                  title: "Automatizacion",
                  text: "Elimina tareas manuales y repetitivas para que tu equipo se enfoque en lo importante.",
              },
              {
                  icon: "commerce",
                  title: "E-commerce",
                  text: "Tiendas online integradas con medios de pago, facturacion, logistica y stock.",
              },
              {
                  icon: "ai",
                  title: "Inteligencia artificial",
                  text: "Chatbots, prediccion de demanda y analisis de datos con IA aplicada a tu negocio.",
              },
              {
                  icon: "integrations",
                  title: "Integraciones",
                  text: "Conectamos SAP, Tango, MercadoPago, WhatsApp y lo que ya uses hoy.",
              },
          ];

const steps = [
    {
        number: "01",
        icon: "discovery",
        title: "Descubrimiento y Analisis",
        text: "Comenzamos entendiendo los objetivos de tu negocio y los requerimientos tecnicos. Definimos juntos el alcance del proyecto y te enviamos una cotizacion personalizada.",
    },
    {
        number: "02",
        icon: "development",
        title: "Desarrollo",
        text: "Desarrollamos tu solucion a medida utilizando tecnologias modernas y practicas agiles. Recibis actualizaciones de progreso en cada sprint.",
    },
    {
        number: "03",
        icon: "testing",
        title: "Pruebas e implementacion",
        text: "Antes del lanzamiento, se validan la funcionalidad, el rendimiento y la usabilidad. Aseguramos una implementacion fluida y sin interrupciones.",
    },
    {
        number: "04",
        icon: "support",
        title: "Soporte continuo",
        text: "Despues de la entrega, brindamos mantenimiento, actualizaciones y optimizacion continua. Tu sistema se mantiene estable y preparado para crecer junto a tu negocio.",
    },
];

const projects = [
    {
        image: "/projects/hexadevs.png",
        title: "Hexadevs",
        text: "Sitio institucional con foco en conversion.",
    },
    {
        image: "/projects/todo-app.svg",
        title: "Taskflow",
        text: "Sistema de tareas y productividad para equipos.",
    },
    {
        image: "/projects/flashcards.svg",
        title: "Learning Hub",
        text: "Plataforma educativa para aprendizaje dinamico.",
    },
    {
        image: "/projects/bunny-js.svg",
        title: "Bunny JS",
        text: "Web app ligera orientada a performance y conversion.",
    },
    {
        image: "/projects/animal.svg",
        title: "Animal UI",
        text: "Landing visual con identidad de marca y narrativa clara.",
    },
];

---

<Layout title="CROBF" description={SITE_DESCRIPTION}>
    <main class="home">
        <section class="hero-intro">
            <div class="hero-intro-content">
                <h1 class="hero-title">
                    {
                        lang === "es" ? (
                            <>
                                <span class="hero-title__line">Creando sistemas</span>
                                <span class="hero-title__line hero-title__swap" data-hero-bottom-swap>
                                    <span class="hero-title__swap-track">
                                        <span class="hero-title__swap-item">
                                            <span class="hero-left-rotate-wrap">
                                                <span
                                                    class="hero-left-rotate"
                                                    data-hero-left-rotate
                                                    data-hero-words="para solucionar|para innovar|para simplificar|para asegurar"
                                                >
                                                    para solucionar
                                                </span>
                                            </span>
                                        </span>
                                    </span>
                                </span>
                            </>
                        ) : (
                            <>
                                <span class="hero-title__line">{copy.heroTitleLine1}</span>
                                <span class="hero-title__line">{copy.heroTitleLine2}</span>
                            </>
                        )
                    }
                </h1>
                <p class="subtitle">{copy.heroText}</p>
                <div class="actions">
                    <a href={`/${lang}/contact#contact_form`} class="btn btn-ghost" onclick={`window.location.href=location.origin + '/${lang}/contact#contact_form'; return false;`} onmousedown={`window.location.href=location.origin + '/${lang}/contact#contact_form'; return false;`}>{copy.heroPrimary}</a>
                    <a href="#services" class="btn btn-primary">{copy.heroSecondary}</a>
                </div>
            </div>
        </section>

        <Carousel3D />

        <!-- services: Ejemplos / Que podemos crear juntos? -->
        <section class="services" id="services" style="margin-top: -24rem;">
            <p class="eyebrow" data-reveal style="--reveal-delay: 0ms;">{copy.servicesSubtitle}</p>
            <h2 data-reveal style="--reveal-delay: 50ms;">{copy.servicesTitle}</h2>
            <div data-reveal style="--reveal-delay: 90ms;">
                <BentoGrid client:load items={serviceItems} />
            </div>
        </section>

        <section class="parallax-flow" id="parallax-flow" aria-hidden="true"></section>

        <section class="hero" id="inicio">
            <div class="hero-visual" aria-hidden="true" data-reveal="right" style="--reveal-delay: 80ms;">
            </div>
        </section>

        <!-- services moved above to sit under the carousel -->

        <section class="process">
            <h2 data-reveal style="--reveal-delay: 40ms;">{copy.processTitle}</h2>
            <div class="process-grid">
                {
                    steps.map((step, index) => (
                        <article class="step-card" style={`--stage-delay: ${index * 1800}ms;`}>
                            <div class="step-dot" aria-hidden="true">
                                {step.icon === "discovery" && (
                                    <svg class="step-icon icon-discovery" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="4.6"></circle>
                                        <line x1="14.6" y1="14.6" x2="18.2" y2="18.2"></line>
                                        <line x1="11" y1="8.5" x2="11" y2="13.5"></line>
                                        <line x1="8.5" y1="11" x2="13.5" y2="11"></line>
                                    </svg>
                                )}
                                {step.icon === "development" && (
                                    <svg class="step-icon icon-development" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <polyline class="dev-left" points="8.2 8.2 4.7 12 8.2 15.8"></polyline>
                                        <polyline class="dev-right" points="15.8 8.2 19.3 12 15.8 15.8"></polyline>
                                        <line class="dev-slash" x1="13.2" y1="6.8" x2="10.8" y2="17.2"></line>
                                    </svg>
                                )}
                                {step.icon === "testing" && (
                                    <svg class="step-icon icon-testing" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <rect x="4.5" y="5.8" width="15" height="12.8" rx="2"></rect>
                                        <polyline class="check-mark" points="8 12.2 10.7 14.9 16 9.6"></polyline>
                                    </svg>
                                )}
                                {step.icon === "support" && (
                                    <svg class="step-icon icon-support" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M4.8 12a7.2 7.2 0 0 1 14.4 0"></path>
                                        <rect x="4.6" y="11.9" width="2.8" height="5.2" rx="1"></rect>
                                        <rect x="16.6" y="11.9" width="2.8" height="5.2" rx="1"></rect>
                                        <path d="M19.4 17.1a3 3 0 0 1-3 3H12"></path>
                                        <rect x="10.5" y="19" width="3" height="1.8" rx="0.8"></rect>
                                    </svg>
                                )}
                            </div>
                            <p class="step-number">{step.number}</p>
                            <h3>{step.title}</h3>
                            <p>{step.text}</p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="portfolio" id="casos-exito">
            <p class="eyebrow" data-reveal>{copy.portfolioSubtitle}</p>
            <h2 data-reveal style="--reveal-delay: 40ms;">{copy.portfolioTitle}</h2>
            <div class="portfolio-row">
                {
                    projects.map((project, index) => (
                        <article class="project-card" data-reveal style={`--reveal-delay: ${70 + index * 45}ms;`}>
                            <div class="project-media">
                                <img src={project.image} alt={project.title} loading="lazy" draggable="false" />
                            </div>
                            <h3>{project.title}</h3>
                            <p>{project.text}</p>
                        </article>
                    ))
                }
            </div>
        </section>

        <YouCanScroll />

        <section class="team" id="about-us">
            <div class="team-copy" data-reveal>
                <p class="eyebrow">{copy.withUsSubtitle}</p>
                <h2>{copy.teamTitle}</h2>
                <p>{copy.teamText}</p>
                <a href={`/${lang}/about`} class="btn btn-primary">{copy.teamAction}</a>
            </div>
        </section>

        <section class="floating-cta" data-reveal>
            <p>{copy.ctaText}</p>
            <a href={`/${lang}/contact#contact_form`} class="btn btn-primary">{copy.ctaAction}</a>
        </section>

        <section class="end-cta" id="contacto">
            <h2 data-reveal>{copy.endTitle}</h2>
            <div class="actions">
                <a href={`/${lang}/contact#contact_form`} class="btn btn-ghost" data-reveal style="--reveal-delay: 40ms;">{copy.endPrimary}</a>
                <a href={`/${lang}/about`} class="btn btn-primary" data-reveal style="--reveal-delay: 70ms;">{copy.endSecondary}</a>
            </div>
        </section>

        <script is:inline>
            const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
            const portfolioRow = document.querySelector(".portfolio-row");
            const heroLeftRotate = document.querySelector("[data-hero-left-rotate]");
            const WORD_LIST_DURATION_MS = 1200;
            const SELECTOR_DURATION_MS = 500;

            if (!reduceMotion) {
                if (heroLeftRotate instanceof HTMLElement) {
                    const words = (heroLeftRotate.dataset.heroWords || "")
                        .split("|")
                        .map((word) => word.trim())
                        .filter(Boolean);

                    if (words.length > 1) {
                        let wordIndex = 0;

                        const changeWord = () => {
                            heroLeftRotate.classList.add("is-leaving");

                            window.setTimeout(() => {
                                wordIndex = (wordIndex + 1) % words.length;
                                heroLeftRotate.style.transition = "none";
                                heroLeftRotate.classList.add("is-hidden");
                                heroLeftRotate.textContent = words[wordIndex];
                                heroLeftRotate.classList.remove("is-leaving");
                                heroLeftRotate.classList.add("is-entering");

                                void heroLeftRotate.offsetWidth;
                                heroLeftRotate.style.transition = "";
                                heroLeftRotate.classList.remove("is-hidden");

                                window.setTimeout(() => {
                                    heroLeftRotate.classList.remove("is-entering");
                                }, SELECTOR_DURATION_MS);
                            }, SELECTOR_DURATION_MS / 2);
                        };

                        window.setTimeout(() => {
                            window.setInterval(changeWord, WORD_LIST_DURATION_MS + 1000);
                        }, WORD_LIST_DURATION_MS + 450);
                    }
                }
            }

            if (portfolioRow instanceof HTMLElement) {
                const DRAG_SPEED = 1.28;
                let isDragging = false;
                let startX = 0;
                let startScrollLeft = 0;
                let draggedDistance = 0;
                let velocity = 0;
                let lastTime = 0;
                let momentumFrame = 0;

                const stopMomentum = () => {
                    if (!momentumFrame) return;
                    window.cancelAnimationFrame(momentumFrame);
                    momentumFrame = 0;
                    portfolioRow.classList.remove("is-momentum");
                };

                const runMomentum = () => {
                    if (Math.abs(velocity) < 0.015) {
                        velocity = 0;
                        momentumFrame = 0;
                        portfolioRow.classList.remove("is-momentum");
                        return;
                    }

                    portfolioRow.scrollLeft += velocity * 16;
                    velocity *= 0.92;
                    momentumFrame = window.requestAnimationFrame(runMomentum);
                };

                const startDrag = (event) => {
                    if (event.pointerType !== "mouse") return;
                    if (event.button !== 0) return;
                    stopMomentum();
                    isDragging = true;
                    startX = event.clientX;
                    startScrollLeft = portfolioRow.scrollLeft;
                    draggedDistance = 0;
                    velocity = 0;
                    lastTime = performance.now();
                    portfolioRow.classList.add("is-dragging");
                    portfolioRow.setPointerCapture(event.pointerId);
                };

                const moveDrag = (event) => {
                    if (!isDragging) return;
                    const now = performance.now();
                    const deltaX = event.clientX - startX;
                    draggedDistance = Math.max(draggedDistance, Math.abs(deltaX));

                    const nextScrollLeft = startScrollLeft - deltaX * DRAG_SPEED;
                    const dt = Math.max(1, now - lastTime);
                    velocity = (nextScrollLeft - portfolioRow.scrollLeft) / dt;

                    portfolioRow.scrollLeft = nextScrollLeft;
                    lastTime = now;

                    if (draggedDistance > 6) {
                        event.preventDefault();
                    }
                };

                const endDrag = (event) => {
                    if (!isDragging) return;
                    isDragging = false;
                    portfolioRow.classList.remove("is-dragging");
                    if (portfolioRow.hasPointerCapture(event.pointerId)) {
                        portfolioRow.releasePointerCapture(event.pointerId);
                    }

                    if (draggedDistance > 6) {
                        portfolioRow.classList.add("is-momentum");
                        momentumFrame = window.requestAnimationFrame(runMomentum);
                    }
                };

                portfolioRow.addEventListener("pointerdown", startDrag);
                portfolioRow.addEventListener("pointermove", moveDrag);
                portfolioRow.addEventListener("pointerup", endDrag);
                portfolioRow.addEventListener("pointercancel", endDrag);
                portfolioRow.addEventListener("pointerleave", endDrag);
                portfolioRow.addEventListener("dragstart", (event) => event.preventDefault());
            }

            if (!reduceMotion) {
                document.querySelectorAll(".tilt-card").forEach((card) => {
                    const layers = card.querySelectorAll(".tilt-layer");
                    const maxRotate = 7;

                    const reset = () => {
                        card.style.transform = "perspective(900px) rotateX(0deg) rotateY(0deg) translateY(0px)";
                        layers.forEach((layer) => {
                            const depth = Number(layer.getAttribute("data-depth") || 0);
                            layer.style.transform = `translateZ(${depth}px)`;
                        });
                    };

                    reset();

                    card.addEventListener("mousemove", (event) => {
                        const rect = card.getBoundingClientRect();
                        const px = (event.clientX - rect.left) / rect.width - 0.5;
                        const py = (event.clientY - rect.top) / rect.height - 0.5;

                        const ry = px * maxRotate * 2;
                        const rx = -py * maxRotate * 2;

                        card.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateY(-2px)`;

                        layers.forEach((layer) => {
                            const depth = Number(layer.getAttribute("data-depth") || 0);
                            const lx = -px * depth * 0.5;
                            const ly = -py * depth * 0.5;
                            layer.style.transform = `translate3d(${lx}px, ${ly}px, ${depth}px)`;
                        });
                    });

                    card.addEventListener("mouseleave", reset);
                    card.addEventListener("blur", reset, true);
                });
            }

            const revealTargets = document.querySelectorAll("[data-reveal]:not([data-reveal-card])");
            const revealCards = document.querySelectorAll("[data-reveal-card]");
            const processSection = document.querySelector(".process");
            const servicesSection = document.querySelector(".services");

            if (reduceMotion) {
                revealTargets.forEach((target) => target.classList.add("is-visible"));
                revealCards.forEach((target) => target.classList.add("is-visible"));
                if (processSection instanceof HTMLElement) {
                    processSection.classList.add("is-line-active");
                }
            } else {
                const revealObserver = new IntersectionObserver(
                    (entries, observer) => {
                        entries.forEach((entry) => {
                            if (!entry.isIntersecting) return;
                            entry.target.classList.add("is-visible");
                            observer.unobserve(entry.target);
                        });
                    },
                    {
                        threshold: 0.05,
                        rootMargin: "0px 0px -1% 0px",
                    }
                );

                revealTargets.forEach((target) => revealObserver.observe(target));

                if (servicesSection instanceof HTMLElement && revealCards.length) {
                    const servicesCardsObserver = new IntersectionObserver(
                        (entries, observer) => {
                            entries.forEach((entry) => {
                                if (!entry.isIntersecting) return;
                                revealCards.forEach((card, index) => {
                                    window.setTimeout(() => {
                                        card.classList.add("is-visible");
                                    }, index * 920);
                                });
                                observer.unobserve(servicesSection);
                            });
                        },
                        {
                            threshold: 0.28,
                            rootMargin: "0px 0px -6% 0px",
                        }
                    );

                    servicesCardsObserver.observe(servicesSection);
                }

                if (processSection instanceof HTMLElement) {
                    const processObserver = new IntersectionObserver(
                        (entries, observer) => {
                            entries.forEach((entry) => {
                                if (!entry.isIntersecting) return;
                                processSection.classList.add("is-line-active");
                                observer.unobserve(processSection);
                            });
                        },
                        {
                            threshold: 0.38,
                            rootMargin: "0px 0px -8% 0px",
                        }
                    );

                    processObserver.observe(processSection);
                }

            }
        </script>
    </main>
</Layout>

<style>
    .home {
        width: min(1120px, calc(100% - 2.2rem));
        margin-inline: auto;
        padding: 1.2rem 0 5rem;
        display: grid;
        gap: 1.8rem;
    }

    [data-reveal] {
        opacity: 0;
        transform: translate3d(0, var(--reveal-y, 22px), 0) scale(0.998);
        filter: none;
        transition:
            opacity var(--reveal-opacity-duration, 1450ms) cubic-bezier(0.16, 1, 0.3, 1),
            transform var(--reveal-transform-duration, 2100ms) cubic-bezier(0.16, 1, 0.3, 1),
            filter var(--reveal-opacity-duration, 1450ms) cubic-bezier(0.16, 1, 0.3, 1);
        transition-delay: var(--reveal-delay, 0ms);
        will-change: opacity, transform, filter;
    }

    [data-reveal="left"] {
        transform: translate3d(-14px, 6px, 0) scale(0.998);
    }

    [data-reveal="right"] {
        transform: translate3d(14px, 6px, 0) scale(0.998);
    }

    [data-reveal].is-visible {
        opacity: 1;
        transform: translate3d(0, 0, 0) scale(1);
        filter: blur(0);
    }

    :global(body) {
        overflow-x: hidden;
    }

    .eyebrow {
        margin: 0 0 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.72rem;
        color: rgba(23, 30, 48, 0.72);
    }

    .hero-intro {
        position: relative;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.2rem;
        align-items: center;
        min-height: auto;
        padding-top: 7.2rem;
        padding-bottom: 0;
        isolation: isolate;
        justify-items: center;
        text-align: center;
        width: 100%;
    }

    .hero-intro-content {
        width: 100%;
        display: grid;
        justify-items: center;
        text-align: center;
        gap: 1.5rem;
        row-gap: 1.8rem;
    }

    /* Mover el bloque hero hacia la izquierda en pantallas grandes */
    @media (min-width: 820px) {
        .hero-intro {
            justify-items: center;
            text-align: center;
            /* mantener padding horizontal, pero centrar el contenido */
            padding-left: 1.3rem;
            padding-right: 1.3rem;
        }

        .hero-intro-content {
            width: min(920px, 70%);
            margin-inline: auto;
            /* Desplazar ligeramente a la izquierda para posicionamiento visual */
            transform: translateX(-6%);
            will-change: transform;
        }
    }

    .hero {
        position: relative;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.2rem;
        align-items: center;
        min-height: auto;
        padding-top: 0;
        margin-top: 0;
        isolation: isolate;
        justify-items: center;
        text-align: center;
    }

    .parallax-flow {
        width: 100%;
        min-height: 0;
        overflow: hidden;
        display: none;
    }

    .hero-copy,
    .hero-visual {
        position: relative;
        z-index: 2;
    }

    .hero-copy {
        width: min(900px, 100%);
        display: grid;
        justify-items: center;
        text-align: center;
        margin-inline: auto;
    }

    h1 {
        font-size: clamp(2rem, 4.6vw, 4.2rem);
        line-height: 1.02;
        margin: 0;
        max-width: 18ch;
    }

    .home h1,
    .home h2,
    .home h3 {
        text-align: center;
        margin-inline: auto;
    }

    .hero-title {
        display: grid;
        gap: 0.05em;
        font-family: "Inter", "Inter Tight", "-apple-system", "BlinkMacSystemFont", "Segoe UI", sans-serif;
        font-weight: 900;
        font-size: clamp(2.8rem, 9.8vw, 90px);
        line-height: 0.95;
        letter-spacing: -0.035em;
        color: rgba(0, 0, 0, 0.98);
        margin: 0;
        max-width: none;
        text-transform: uppercase;
    }

    .hero-title__line {
        display: block;
        white-space: nowrap;
    }

    .hero-title__swap {
        position: relative;
        display: inline-block;
    }

    .hero-title__swap-track {
        display: block;
        transform: none;
    }

    .hero-title__swap.is-shifted .hero-title__swap-track {
        transform: none;
    }

    .hero-title__swap-item {
        display: none;
    }
    
    .hero-title__swap-item:first-child {
        display: inline;
    }

    .hero-left-rotate {
        display: block;
        width: 100%;
        text-align: center;
        transition: transform 500ms ease, opacity 500ms ease;
        will-change: transform, opacity;
    }

    .hero-left-rotate-wrap {
        display: inline-block;
        min-width: 15ch;
        overflow: clip;
        contain: paint;
    }

    .hero-left-rotate.is-leaving {
        opacity: 0;
        transform: translateX(-0.28em);
    }

    .hero-left-rotate.is-entering {
        opacity: 0;
        transform: translateX(0.28em);
    }

    .hero-left-rotate.is-hidden {
        opacity: 0;
        transform: translateX(0);
    }

    h2 {
        font-size: clamp(1.7rem, 3vw, 2.8rem);
        margin: 0;
        max-width: 20ch;
        line-height: 1.1;
    }

    .subtitle {
        color: rgba(23, 30, 48, 0.78);
        max-width: 52ch;
        margin: 0;
    }

    .hero-meta {
        margin: 0.95rem 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.34rem;
        font-size: 1.03rem;
        line-height: 1.3;
        font-weight: 500;
        color: rgba(31, 42, 72, 0.72);
        justify-items: center;
    }

    .hero-meta li::before {
        content: "+ ";
        color: #4d6eff;
        font-weight: 700;
    }

    .actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        justify-content: center;
        margin: 0;
    }

    .btn {
        padding: 0.72rem 1.2rem;
        border-radius: 999px;
        font-size: 0.86rem;
        letter-spacing: 0.02em;
        text-decoration: none;
        border: 1px solid transparent;
        transition: transform 140ms ease, box-shadow 140ms ease;
    }

    .btn:hover {
        transform: translateY(-1px);
    }

    .btn-primary {
        background: linear-gradient(120deg, #1f34f3, #4c6aff);
        color: #f6f8ff;
        box-shadow: 0 10px 30px rgba(41, 76, 255, 0.25);
    }

    .btn-ghost {
        border-color: rgba(41, 76, 255, 0.4);
        color: #263575;
        background: rgba(255, 255, 255, 0.68);
    }

    .hero-visual {
        display: none;
    }

    .hero-visual::before {
        content: none;
    }

    .services-grid {
        margin-top: 1.6rem;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.55rem;
    }

    .services {
        background: transparent;
        border-radius: 0;
        padding: 2.2rem 1.7rem 2.5rem;
        border: 0;
        margin-top: 12rem;
    }

    .services > .eyebrow,
    .services > h2 {
        text-align: center;
        margin-inline: auto;
        transform: translateY(-0.55rem);
    }

    .services > .eyebrow {
        color: rgba(32, 46, 78, 0.78);
        margin-bottom: 0.8rem;
    }

    .services > h2 {
        color: rgba(19, 28, 52, 0.98);
        max-width: 12ch;
        font-size: clamp(2.2rem, 4.3vw, 3.25rem);
    }

    .service-card {
        position: relative;
        overflow: hidden;
        isolation: isolate;
        transform-style: preserve-3d;
        border: 1px solid rgba(70, 103, 190, 0.28);
        border-radius: 1rem;
        background:
            radial-gradient(90% 62% at 18% 2%, rgba(255, 255, 255, 0.7) 0%, rgba(255, 255, 255, 0) 55%),
            linear-gradient(135deg, #ffffff 0%, #f6f9ff 52%, #eef3ff 100%);
        min-height: 196px;
        display: grid;
        align-items: start;
        gap: 0.58rem;
        padding: 1.22rem 1.28rem 1.14rem;
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.5) inset,
            0 0 14px rgba(69, 109, 236, 0.2),
            0 10px 24px rgba(26, 44, 94, 0.14);
        transform-style: preserve-3d;
        transition: transform 220ms ease;
        will-change: transform;
        text-align: center;
        justify-items: center;
    }

    .service-card[data-reveal] {
        opacity: 0;
        transform: translate3d(-14px, 28px, 0) scale(0.992);
        filter: none;
        transition: none;
    }

    .service-card[data-reveal].is-visible {
        opacity: 0;
        transform: translate3d(-14px, 28px, 0) scale(0.992);
        filter: none;
        animation: serviceCardReveal 2300ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
        will-change: transform, opacity;
    }

    .tilt-layer {
        transform-style: preserve-3d;
        transition: transform 220ms ease;
        will-change: transform;
    }

    .service-card::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        pointer-events: none;
        box-shadow: 0 0 0 1px rgba(59, 108, 244, 0.22) inset;
    }

    .service-card::after {
        content: "";
        position: absolute;
        left: 0;
        right: 0;
        bottom: 0;
        height: 20px;
        border-radius: 0 0 1rem 1rem;
        background:
            radial-gradient(circle at 1px 1px, rgba(58, 118, 255, 0.3) 1px, transparent 1.2px),
            linear-gradient(180deg, rgba(34, 76, 224, 0) 0%, rgba(26, 86, 255, 0.2) 100%);
        background-size: 3px 3px, 100% 100%;
        background-repeat: repeat, no-repeat;
        opacity: 0.62;
        pointer-events: none;
    }

    .service-icon {
        width: 28px;
        height: 28px;
        border-radius: 0.45rem;
        display: grid;
        place-items: center;
        background: linear-gradient(140deg, #1d49db, #3058f6);
        border: 1px solid rgba(123, 153, 255, 0.92);
        box-shadow: 0 0 16px rgba(82, 122, 255, 0.5);
        position: relative;
        color: rgba(244, 248, 255, 0.96);
    }

    .service-icon::after {
        content: "";
        position: absolute;
        inset: -10px;
        border-radius: 0.7rem;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0));
        filter: blur(3px);
        z-index: -1;
    }

    .service-icon svg {
        width: 18px;
        height: 18px;
    }

    .service-card h3 {
        margin: 0.7rem 0 0;
        font-size: clamp(1.75rem, 1.9vw, 2.05rem);
        line-height: 1.08;
        font-weight: 600;
        color: rgba(16, 24, 48, 0.96);
        letter-spacing: -0.015em;
    }

    .service-card p {
        margin: 0;
        font-size: 0.92rem;
        line-height: 1.4;
        color: rgba(33, 48, 84, 0.9);
        max-width: 29ch;
    }

    .process {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: 4.2rem clamp(1.1rem, 3vw, 2.2rem) 4.8rem;
        background: transparent;
    }

    .process > h2 {
        text-align: center;
        margin-inline: auto;
        color: #101a35;
        width: min(1020px, calc(100% - 2.2rem));
        font-size: clamp(2.2rem, 4.2vw, 3.8rem);
        letter-spacing: -0.02em;
        line-height: 1.04;
    }

    .process-grid {
        margin-top: 2.35rem;
        width: min(1080px, calc(100% - 2.2rem));
        margin-inline: auto;
        --process-gap: 1.35rem;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.35rem;
        position: relative;
        align-items: start;
        isolation: isolate;
    }

    .step-card {
        position: relative;
        z-index: 1;
        text-align: center;
        padding-top: 0.2rem;
        opacity: 0;
        transform: translate3d(0, 26px, 0);
        transition:
            opacity 1400ms cubic-bezier(0.22, 1, 0.36, 1),
            transform 1900ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: calc(320ms + var(--stage-delay, 0ms));
    }

    .step-card::after {
        content: "";
        position: absolute;
        top: 47px;
        left: calc(50% + 47px);
        width: calc(100% + var(--process-gap, 1.35rem) - 94px);
        height: 2px;
        background: linear-gradient(90deg, rgba(62, 101, 207, 0.6) 0%, rgba(51, 90, 201, 0.82) 100%);
        transform: scaleX(0);
        transform-origin: left center;
        transition: transform 1350ms cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: calc(760ms + var(--stage-delay, 0ms));
        z-index: 3;
        pointer-events: none;
    }

    .step-card:last-child::after {
        display: none;
    }

    .process.is-line-active .step-card {
        opacity: 1;
        transform: translate3d(0, 0, 0);
    }

    .process.is-line-active .step-card::after {
        transform: scaleX(1);
    }

    .step-dot {
        width: 94px;
        height: 94px;
        border-radius: 999px;
        border: 3px solid #2f52ff;
        box-shadow: 0 0 0 2px rgba(36, 79, 255, 0.12), 0 0 18px rgba(37, 86, 255, 0.24);
        background: #f9fbff;
        margin: 0 auto;
        display: grid;
        place-items: center;
        color: rgba(24, 42, 88, 0.96);
    }

    .step-icon {
        width: 46px;
        height: 46px;
        animation: iconFloat 2.8s ease-in-out infinite;
        transform-origin: center;
    }

    .icon-discovery {
        animation: iconSearch 3.2s ease-in-out infinite;
    }

    .icon-development {
        animation: iconPulse 2.4s ease-in-out infinite;
    }

    .icon-testing {
        animation: iconCheck 2.6s ease-in-out infinite;
    }

    .icon-support {
        animation: iconSpin 3.8s linear infinite;
    }

    .icon-development .dev-left,
    .icon-development .dev-right {
        animation: devBracket 1.9s ease-in-out infinite;
    }

    .icon-development .dev-right {
        animation-delay: 120ms;
    }

    .icon-testing .check-mark {
        stroke-dasharray: 12;
        stroke-dashoffset: 12;
        animation: drawCheck 2.2s ease-in-out infinite;
    }

    @keyframes iconFloat {
        0%,
        100% {
            transform: translateY(0px);
            opacity: 0.92;
        }
        50% {
            transform: translateY(-1.8px);
            opacity: 1;
        }
    }

    @keyframes iconPulse {
        0%,
        100% {
            transform: scale(0.94);
        }
        50% {
            transform: scale(1.08);
        }
    }

    @keyframes iconCheck {
        0%,
        100% {
            opacity: 0.82;
        }
        50% {
            opacity: 1;
        }
    }

    @keyframes iconSpin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }

    @keyframes iconSearch {
        0%,
        100% {
            transform: translateY(0) rotate(0deg);
        }
        35% {
            transform: translateY(-1px) rotate(-8deg);
        }
        70% {
            transform: translateY(1px) rotate(8deg);
        }
    }

    @keyframes devBracket {
        0%,
        100% {
            transform: translateX(0);
        }
        50% {
            transform: translateX(1.6px);
        }
    }

    @keyframes drawCheck {
        0%,
        15% {
            stroke-dashoffset: 12;
            opacity: 0.75;
        }
        45%,
        70% {
            stroke-dashoffset: 0;
            opacity: 1;
        }
        100% {
            stroke-dashoffset: 0;
            opacity: 0.9;
        }
    }

    @keyframes serviceCardReveal {
        0% {
            opacity: 0;
            transform: translate3d(-14px, 28px, 0) scale(0.992);
        }
        58% {
            opacity: 0.84;
            transform: translate3d(-4px, 10px, 0) scale(0.997);
        }
        100% {
            opacity: 1;
            transform: translate3d(0, 0, 0) scale(1);
        }
    }

    .step-number {
        margin: 1.1rem 0 0.85rem;
        font-size: clamp(2.2rem, 3.35vw, 3.45rem);
        font-weight: 500;
        letter-spacing: 0.02em;
        color: rgba(16, 27, 56, 0.96);
        line-height: 1;
    }

    .step-card h3 {
        margin: 0;
        font-size: clamp(1.08rem, 1.55vw, 1.9rem);
        color: rgba(21, 32, 62, 0.98);
        line-height: 1.2;
    }

    .step-card p {
        margin: 1.05rem auto 0;
        font-size: clamp(0.9rem, 1vw, 1.03rem);
        line-height: 1.65;
        color: rgba(35, 51, 86, 0.9);
        max-width: 32ch;
    }

    .portfolio {
        width: 100vw;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        background: transparent;
        padding: 2.8rem 0 clamp(1.6rem, 2.2vw, 2.2rem);
    }

    .portfolio > .eyebrow,
    .portfolio > h2 {
        text-align: center;
        margin-inline: auto;
        width: min(1120px, calc(100% - 2.6rem));
        color: rgba(20, 31, 61, 0.95);
    }

    .portfolio > .eyebrow {
        color: rgba(52, 69, 108, 0.78);
    }

    .portfolio > h2 {
        max-width: 16ch;
        margin-top: 0.1rem;
        font-size: clamp(2rem, 3.5vw, 3.1rem);
        line-height: 1.05;
    }

    .portfolio-row {
        margin-top: 1.8rem;
        width: min(1120px, calc(100% - 2.6rem));
        margin-inline: auto;
        display: flex;
        gap: clamp(0.75rem, 1vw, 1rem);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scroll-padding-inline: 0.4rem;
        scroll-behavior: auto;
        overscroll-behavior-x: contain;
        touch-action: pan-x pinch-zoom;
        -webkit-overflow-scrolling: touch;
        padding: 0.2rem 0 0.9rem;
        scrollbar-width: none;
        -ms-overflow-style: none;
        cursor: grab;
    }

    .portfolio-row.is-dragging {
        cursor: grabbing;
        user-select: none;
        scroll-snap-type: none;
    }

    .portfolio-row.is-momentum {
        scroll-snap-type: x proximity;
    }

    .portfolio-row::-webkit-scrollbar {
        display: none;
    }

    .project-card {
        scroll-snap-align: start;
        scroll-snap-stop: always;
        flex: 0 0 clamp(220px, 24vw, 300px);
        width: clamp(220px, 24vw, 300px);
        background: transparent;
        border: 0;
        min-height: unset;
        display: grid;
        gap: 0.78rem;
        text-align: center;
        justify-items: center;
    }

    .project-media {
        width: 100%;
        border-radius: 1.3rem;
        overflow: hidden;
        aspect-ratio: 1 / 1;
        background: #0f1117;
        box-shadow: 0 14px 34px rgba(0, 0, 0, 0.42);
    }

    .project-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 360ms ease;
        -webkit-user-drag: none;
        user-select: none;
        pointer-events: none;
    }

    .project-card:hover img {
        transform: scale(1.03);
    }

    .project-card h3 {
        margin: 0;
        width: 100%;
        font-size: 1.06rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: rgba(18, 29, 56, 0.98);
    }

    .project-card p {
        margin: 0;
        width: 100%;
        font-size: 0.95rem;
        color: rgba(51, 67, 106, 0.84);
        line-height: 1.35;
        max-width: 100%;
    }

    .project-card--empty .project-media {
        border: 1px dashed rgba(112, 136, 187, 0.42);
        background: linear-gradient(145deg, rgba(244, 248, 255, 0.95), rgba(234, 240, 252, 0.95));
        box-shadow: none;
    }

    .team {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
        align-items: center;
    }

    .team-copy {
        text-align: center;
        justify-items: center;
        display: grid;
    }

    .team-copy .eyebrow {
        color: rgba(34, 48, 82, 0.8);
    }

    .team-copy h2 {
        color: rgba(16, 27, 56, 0.98);
    }

    .team-copy p {
        color: rgba(40, 56, 93, 0.9);
    }

    .floating-cta {
        border-radius: 0;
        padding: 2rem 1.6rem;
        background: transparent;
        border: 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }

    .floating-cta p {
        margin: 0;
        max-width: 32ch;
        font-size: 1.2rem;
        line-height: 1.15;
        color: rgba(18, 30, 60, 0.95);
    }

    .end-cta {
        text-align: center;
        padding: 0.7rem 0 2.2rem;
    }

    .end-cta h2 {
        color: rgba(16, 27, 56, 0.98);
    }

    :global(html:not(.dark)) .team-copy .eyebrow {
        color: #25365f !important;
    }

    :global(html:not(.dark)) .team-copy h2 {
        color: #111c3a !important;
    }

    :global(html:not(.dark)) .team-copy p {
        color: #27375d !important;
    }

    :global(html:not(.dark)) .floating-cta p {
        color: #142044 !important;
    }

    :global(html:not(.dark)) .end-cta h2 {
        color: #111c3a !important;
    }

    .end-cta h2 {
