---
import { getCollection, render } from "astro:content";
import BlogPost from "../../../layouts/BlogPost.astro";

const { lang, slug } = Astro.params;
const fullId = `${lang}/${slug}`;

const allPosts = await getCollection("blog");
const post = allPosts.find((entry) => entry.id === fullId);

if (!post) {
    return new Response(null, { status: 404 });
}

const { Content } = await render(post);

// Find related posts (same language, same tag, different post)
const sameLangPosts = allPosts
    .filter((p) => p.id.startsWith(`${lang}/`) && p.id !== post.id)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postTags = post.data.tags ?? [];
const tagMatches = postTags.length > 0
    ? sameLangPosts.filter((p) => (p.data.tags ?? []).some((t) => postTags.includes(t)))
    : [];
const fallback = sameLangPosts.filter((p) => !tagMatches.includes(p));
const related = [...tagMatches, ...fallback].slice(0, 3);

const safeLang = (lang === "en" ? "en" : "es") as "es" | "en";
---

<BlogPost
    title={post.data.title}
    description={post.data.description ?? ""}
    pubDate={post.data.pubDate}
    updatedDate={post.data.updatedDate}
    heroImage={post.data.heroImage}
    author={post.data.author}
    slug={post.id}
    tags={post.data.tags ?? []}
    readingTime={post.data.readingTime}
    lang={safeLang}
    related={related.map((p) => ({
        slug: p.id,
        title: p.data.title,
        description: p.data.description ?? "",
        heroImage: p.data.heroImage,
        pubDate: p.data.pubDate,
        author: p.data.author ?? "CROBF",
    }))}
>
    <Content />
</BlogPost>
