---
import Layout from "../../../layouts/Layout.astro";
import { getLangFromUrl } from "../../../i18n/translate";

const lang = getLangFromUrl(Astro.url);
---

<Layout title="Catálogo Digital - CROBF" description="Catálogo premium: Estética moderna y conversión ágil.">
    <main class="project-detail">
        <h1 class="project-title">CATÁLOGO DIGITAL</h1>

        <div class="project-info">
            <div class="info-column">
                <p class="info-label">ROLE / SERVICES</p>
                <p class="info-value">E-commerce & Development</p>
            </div>
            <div class="info-column">
                <p class="info-label">LOCATION & YEAR</p>
                <p class="info-value">Argentina © 2025</p>
            </div>
        </div>

        <div class="project-image">
            <img src="/images/olympo-phone-screen.png" alt="Catálogo Digital" />
        </div>
    </main>
</Layout>

<style>
    .project-detail {
        width: min(1400px, calc(100% - 4rem));
        margin-inline: auto;
        padding: 8rem 2rem 5rem;
    }

    .project-title {
        font-size: clamp(3rem, 8vw, 6rem);
        font-weight: 400;
        letter-spacing: -0.02em;
        margin: 0 0 4rem 0;
        line-height: 1;
        color: hsl(var(--foreground));
    }

    .project-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 3rem;
        margin-bottom: 5rem;
        padding-bottom: 3rem;
        border-bottom: 1px solid hsl(var(--border));
    }

    .info-column {
        display: grid;
        gap: 1rem;
    }

    .info-label {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: hsl(var(--foreground) / 0.5);
        margin: 0;
    }

    .info-value {
        font-size: 1.1rem;
        color: hsl(var(--foreground));
        margin: 0;
        line-height: 1.4;
    }

    .project-image {
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        border-radius: 0.5rem;
        background: hsl(var(--muted));
    }

    .project-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media (max-width: 768px) {
        .project-detail {
            padding: 6rem 1.5rem 3rem;
        }

        .project-title {
            margin-bottom: 2.5rem;
        }

        .project-info {
            gap: 2rem;
            margin-bottom: 3rem;
        }
    }
</style>
