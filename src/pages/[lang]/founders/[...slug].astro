---
import { getCollection, render } from "astro:content";
import FounderLayout from "../../../layouts/FounderLayout.astro";

const { lang, slug } = Astro.params;
const fullId = `${lang}/${slug}`;

const allFounders = await getCollection("founder");
const documentation = allFounders.find((post) => post.id === fullId);

if (!documentation) {
    return new Response(null, { status: 404 });
}

const { Content } = await render(documentation);
---

<FounderLayout {...documentation.data}>
    <Content />
</FounderLayout>
