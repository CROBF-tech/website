---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import CardFounder from "../../components/CardFounder.astro";
import { SITE_TITLE } from "../../consts";
import { useTranslations, getLangFromUrl } from "../../i18n/translate";
import { GlobePulse } from "../../components/ui/cobe-globe-pulse";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allFounders = await getCollection("founder");
const teamMembers = allFounders
    .filter(f => f.id.startsWith(`${lang}/`) && f.data.index !== undefined)
    .sort((a, b) => (a.data.index ?? 99) - (b.data.index ?? 99));
---

<Layout title={`${t("about.title")} - ${SITE_TITLE}`} description={t("about.description") as string} lang={lang}>
    <main class="about-main">
        <div class="container">
            <!-- Hero Section -->
            <section class="hero-section">
                <h1 class="hero-title">SOBRE NOSOTROS</h1>
            </section>

            <!-- Who We Are Section removed per request -->

            <!-- Team Grid -->
            <section class="team-section">
                <div class="team-grid">
                    {teamMembers.map((member) => {
                        const slug = member.id.replace(`${lang}/`, '');
                        const link = `/founders/${slug}`;
                        const card = (
                            <CardFounder
                                name={member.data.title}
                                image={member.data.heroImage ?? ''}
                                github={member.data.github ?? ''}
                                linkedin={member.data.linkedin ?? ''}
                                link={link}
                                profession={member.data.profession ?? ''}
                                description={member.data.description}
                            />
                        );
                        return member.data.centerCol
                            ? <div class="team-center-col">{card}</div>
                            : card;
                    })}
                </div>
            </section>

            <!-- Globe Section -->
            <section class="globe-section">
                <div class="globe-container">
                    <GlobePulse 
                        client:load 
                        speed={0}
                        markers={[
                            { id: "pulse-1", location: [-32.8895, -68.8458], delay: 0 },
                        ]}
                    />
                </div>
                <p class="section-description">
                    Con base en Argentina y años de trayectoria como desarrolladores de software, volcamos toda nuestra experiencia en crear soluciones web interactivas, animadas y únicas en su clase, trabajando con clientes de cualquier parte del mundo.
                </p>

                <!-- Services Grid -->
                <div class="services-help-section">
                    <h2 class="services-help-title">Podemos ayudarte con ...</h2>
                    <div class="services-help-grid">
                        <div class="service-help-item">
                            <span class="service-number">01</span>
                            <h3 class="service-help-heading">Diseño</h3>
                            <p class="service-help-text">
                                Creamos interfaces estéticas y funcionales centradas en el usuario. Diseñamos experiencias modernas, optimizadas para cualquier dispositivo y enfocadas en potenciar la conversión de tu negocio.
                            </p>
                        </div>
                        <div class="service-help-item">
                            <span class="service-number">02</span>
                            <h3 class="service-help-heading">Desarrollo</h3>
                            <p class="service-help-text">
                                Construimos soluciones tecnológicas utilizando stacks modernos. Nos enfocamos en el rendimiento, la seguridad y un código limpio que permita que tu plataforma crezca sin limitaciones técnicas.
                            </p>
                        </div>
                        <div class="service-help-item">
                            <span class="service-number">03</span>
                            <h3 class="service-help-heading">✦ El paquete completo</h3>
                            <p class="service-help-text">
                                Un sitio web completo, desde el concepto hasta la implementación: eso es lo que nos distingue. Nuestro gran sentido del diseño y nuestras habilidades de desarrollo nos permiten crear proyectos increíbles.
                            </p>
                        </div>
                    </div>
                </div>
            </section>


        </div>
    </main>
</Layout>
<style>
    .about-main {
        position: relative;
        padding: 2rem 0;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* Hero Section */
    .hero-section {
        text-align: center;
        margin-bottom: 4rem;
        padding: 2rem 0;
    }

    .hero-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: var(--color-bright-gray-950);
        line-height: 1.2;
    }

    :global(html.dark) .hero-title {
        color: var(--color-bright-gray-50);
    }

    .accent-text {
        color: var(--accent);
        background: linear-gradient(135deg, var(--accent), var(--color-blue-700));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-description {
        font-size: 1.25rem;
        line-height: 1.6;
        color: var(--color-bright-gray-500);
        max-width: 800px;
        margin: 0 auto;
    }

    :global(html.dark) .hero-description {
        color: var(--color-bright-gray-100);
    }

    /* Section Styling */
    .section {
        margin-bottom: 4rem;
    }

    .section-title {
        font-size: clamp(2rem, 4vw, 2.5rem);
        font-weight: 600;
        margin-bottom: 1.5rem;
        color: var(--color-bright-gray-950);
        text-align: center;
    }

    :global(html.dark) .section-title {
        color: var(--color-bright-gray-50);
    }

    .section-description {
        font-size: 1.5rem;
        line-height: 1.7;
        color: var(--color-bright-gray-950);
        max-width: 650px;
        margin: 0 auto 2rem;
        text-align: center;
        letter-spacing: -0.01em;
    }

    :global(html.dark) .section-description {
        color: var(--color-bright-gray-100);
    }

    /* Team Section */
    .team-section {
        margin-bottom: 5rem;
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        justify-items: center;
        align-items: start;
        margin-bottom: 3rem;
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        justify-content: center;
        width: 100%;
    }

    /* Make first card span full width and center it (1 above, 3 below) */
    .team-grid > :first-child {
        grid-column: 1 / -1;
        justify-self: center;
        max-width: 720px;
    }

    /* Explicit center-column helper for selected cards */
    .team-center-col {
        grid-column: 2 / 3;
        justify-self: center;
        width: 100%;
        display: flex;
        justify-content: center;
    }

    /* Place special cards in center column on desktop */
    .team-grid > :nth-child(5),
    .team-grid > :nth-child(7) {
        grid-column: 2 / 3;
        justify-self: center;
    }

    @media (max-width: 1024px) {
        .team-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .team-grid > :first-child {
            grid-column: 1 / -1;
            max-width: 640px;
        }

        .team-center-col {
            grid-column: 1 / -1;
        }

        .team-grid > :nth-child(5),
        .team-grid > :nth-child(7) {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 768px) {
        .team-grid {
            grid-template-columns: 1fr;
            gap: 1.25rem;
        }

        .team-grid > :first-child {
            grid-column: 1 / -1;
            max-width: 100%;
        }

        .team-center-col {
            grid-column: 1 / -1;
        }
    }


    .team-values {
        text-align: center;
        margin-top: 3rem;
        padding: 2rem;
        background: transparent !important;
        border-radius: 16px;
        border-left: 4px solid var(--accent);
    }

    :global(html.dark) .team-values {
        background: transparent !important;
        border-left-color: var(--accent);
    }

    .team-values p {
        font-size: 1.125rem;
        line-height: 1.6;
        margin: 0;
        color: var(--color-bright-gray-500);
        font-style: italic;
    }

    :global(html.dark) .team-values p {
        color: var(--color-bright-gray-100);
    }

    /* Philosophy Section */
    .philosophy-section {
        background: transparent !important;
        border-radius: 24px;
        padding: 3rem 2rem;
        margin: 4rem 0;
    }

    /* Globe Section */
    .globe-section {
        margin: 5rem 0;
        padding: 3rem 0;
    }

    .globe-container {
        max-width: 1100px;
        width: 1100px;
        height: 550px;
        margin: 0 auto;
        padding: 0;
        overflow: hidden;
        position: relative;
    }

    .globe-container :global(.relative) {
        position: absolute;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 1100px !important;
        height: 1100px !important;
    }

    /* Services Help Section */
    .services-help-section {
        margin-top: 5rem;
        padding: 0 2rem;
    }

    .services-help-title {
        font-size: clamp(2rem, 4vw, 2.5rem);
        font-weight: 400;
        margin-bottom: 3rem;
        color: var(--color-bright-gray-950);
        text-align: left;
    }

    :global(html.dark) .services-help-title {
        color: var(--color-bright-gray-50);
    }

    .services-help-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 3rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .service-help-item {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .service-number {
        font-size: 0.875rem;
        color: var(--color-bright-gray-400);
        font-weight: 300;
    }

    :global(html.dark) .service-number {
        color: var(--color-bright-gray-500);
    }

    .service-help-heading {
        font-size: 1.75rem;
        font-weight: 500;
        color: var(--color-bright-gray-950);
        margin: 0;
    }

    :global(html.dark) .service-help-heading {
        color: var(--color-bright-gray-50);
    }

    .service-help-text {
        font-size: 1.125rem;
        line-height: 1.6;
        color: var(--color-bright-gray-600);
        margin: 0;
    }

    :global(html.dark) .service-help-text {
        color: var(--color-bright-gray-300);
    }

    @media (max-width: 1024px) {
        .services-help-grid {
            grid-template-columns: 1fr;
            gap: 2.5rem;
        }
    }

    @media (max-width: 768px) {
        .services-help-section {
            margin-top: 3rem;
            padding: 0 1rem;
        }

        .services-help-title {
            font-size: clamp(1.5rem, 5vw, 2rem);
            margin-bottom: 2rem;
        }

        .globe-container {
            max-width: 100%;
            padding: 1rem;
        }

        .globe-section {
            margin: 3rem 0;
            padding: 2rem 0;
        }
    }

    :global(html.dark) .philosophy-section {
        background: transparent !important;
    }

    .motto {
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 600;
        text-align: center;
        margin: 2rem 0;
        color: var(--accent);
        font-style: italic;
        line-height: 1.4;
    }

    /* Contact Section */
    .contact-section {
        margin-top: 4rem;
        display: flex;
        justify-content: center;
    }

    .contact-card {
        background: transparent !important;
        border: 2px solid var(--accent);
        border-radius: 20px;
        padding: 2.5rem;
        max-width: 600px;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    :global(html.dark) .contact-card {
        background: transparent !important;
        border-color: var(--accent);
    }

    .contact-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: linear-gradient(90deg, var(--accent), var(--color-blue-700));
    }

    .contact-title {
        font-size: 1.75rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: var(--color-bright-gray-950);
    }

    :global(html.dark) .contact-title {
        color: var(--color-bright-gray-50);
    }

    .contact-description {
        font-size: 1.125rem;
        line-height: 1.6;
        margin: 0;
        color: var(--color-bright-gray-500);
    }

    :global(html.dark) .contact-description {
        color: var(--color-bright-gray-100);
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .about-main {
            padding: 1rem 0;
        }

        .container {
            padding: 0 1rem;
        }

        .hero-section {
            margin-bottom: 3rem;
            padding: 1rem 0;
        }

        .hero-title {
            font-size: clamp(1.8rem, 6vw, 3rem);
        }

        .section {
            margin-bottom: 3rem;
        }

        .section-title {
            font-size: clamp(1.5rem, 5vw, 2rem);
        }

        .section-description {
            font-size: 1rem;
            max-width: 100%;
        }

        .team-values {
            padding: 1.5rem;
            margin-top: 2rem;
        }

        .team-values p {
            font-size: 1rem;
        }

        .philosophy-section {
            padding: 2rem 1.5rem;
            margin: 3rem 0;
        }

        .motto {
            font-size: clamp(1.2rem, 4vw, 1.6rem);
        }

        .contact-card {
            padding: 2rem 1.5rem;
            max-width: 100%;
        }

        .contact-title {
            font-size: 1.4rem;
        }

        .contact-description {
            font-size: 1rem;
        }
    }

    @media (max-width: 480px) {
        .container {
            padding: 0 0.75rem;
        }

        .hero-section {
            margin-bottom: 2rem;
        }

        .hero-title {
            font-size: clamp(1.5rem, 8vw, 2.2rem);
        }

        .section {
            margin-bottom: 2.5rem;
        }

        .team-grid {
            gap: 1rem;
        }

        .team-values {
            padding: 1rem;
        }

        .philosophy-section {
            padding: 1.5rem 1rem;
            margin: 2rem 0;
        }

        .contact-card {
            padding: 1.5rem 1rem;
        }
    }

    /* High contrast mode support */
    @media (prefers-contrast: high) {
        .card {
            border: 2px solid var(--color-bright-gray-950);
        }

        :global(html.dark) .card {
            border-color: var(--color-bright-gray-50);
        }

        .contact-card {
            border-width: 3px;
        }

        .team-values {
            border-left-width: 6px;
        }
    }

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
        .card,
        .card img,
        .card-overlay,
        .social-link {
            transition: none;
        }

        .card:hover {
            transform: none;
        }

        .card:hover img {
            transform: none;
        }
    }
</style>
