---
import FormattedDate from "../components/FormattedDate.astro";
import Layout from "./Layout.astro";
import IconArrowBack from "../components/svgs/IconArrowBack.astro";
import IconX from "../components/svgs/IconX.astro";
import IconLinkedin from "../components/svgs/IconLinkedin.astro";
import IconCopy from "../components/svgs/IconCopy.astro";

type RelatedPost = {
    slug: string;
    title: string;
    description: string;
    heroImage?: string;
    pubDate: Date;
    author: string;
};

type Props = {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    heroImage?: string;
    author?: string;
    slug?: string;
    tags?: string[];
    readingTime?: number;
    lang?: "es" | "en";
    related?: RelatedPost[];
};

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    author,
    slug,
    tags = [],
    readingTime,
    lang = "es",
    related = [],
} = Astro.props;

const copy = {
    es: {
        back: "Volver al blog",
        writtenBy: "Escrito por",
        publishedOn: "Publicado el",
        updatedOn: "Actualizado el",
        readingTime: (n: number) => `${n} min de lectura`,
        share: "Compartir",
        shareLinks: { twitter: "Compartir en X", linkedin: "Compartir en LinkedIn", copy: "Copiar enlace" },
        tagsLabel: "Temas",
        relatedTitle: "Sigue leyendo",
        relatedEmpty: "No hay artículos relacionados.",
        copyLink: "¡Enlace copiado!",
        minuteShort: "min",
    },
    en: {
        back: "Back to blog",
        writtenBy: "Written by",
        publishedOn: "Published on",
        updatedOn: "Updated on",
        readingTime: (n: number) => `${n} min read`,
        share: "Share",
        shareLinks: { twitter: "Share on X", linkedin: "Share on LinkedIn", copy: "Copy link" },
        tagsLabel: "Topics",
        relatedTitle: "Keep reading",
        relatedEmpty: "No related posts.",
        copyLink: "Link copied!",
        minuteShort: "min",
    },
}[lang];

const shareUrl = Astro.url.toString();
---

<Layout title={title} description={description} type="article" image={heroImage} lang={lang} publishedTime={pubDate.toISOString()} author={author}>
    <main class="blog-post">
        <div class="blog-post__nav">
            <a href={`/${lang}/blog`} class="back-link" rel="up">
                <IconArrowBack />
                <span>{copy.back}</span>
            </a>
        </div>

        <article class="post-article" data-article>
            <header class="post-header">
                {tags.length > 0 && (
                    <ul class="post-tags-inline" aria-label={copy.tagsLabel}>
                        {tags.slice(0, 4).map((tag) => (
                            <li>
                                <a href={`/${lang}/blog?tag=${encodeURIComponent(tag)}`} class="post-tag-inline">
                                    {tag}
                                </a>
                            </li>
                        ))}
                    </ul>
                )}

                <h1 class="post-title">{title}</h1>

                {description && <p class="post-lede">{description}</p>}

                <div class="post-meta-row">
                    {author && (
                        <div class="post-author">
                            <span class="avatar-fallback">{(author || "C")[0]}</span>
                            <div>
                                <span class="meta-label">{copy.writtenBy}</span>
                                <span class="meta-value">{author}</span>
                            </div>
                        </div>
                    )}

                    <div class="meta-block">
                        <span class="meta-label">{copy.publishedOn}</span>
                        <span class="meta-value">
                            <FormattedDate date={pubDate} lang={lang} />
                        </span>
                    </div>

                    {readingTime && (
                        <div class="meta-block meta-block--reading-time">
                            <svg class="meta-reading-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <span class="meta-value meta-value--reading-time">{copy.readingTime(readingTime)}</span>
                        </div>
                    )}
                </div>

                {updatedDate && (
                    <p class="post-updated">
                        {copy.updatedOn} <FormattedDate date={updatedDate} lang={lang} />
                    </p>
                )}
            </header>

            {heroImage && (
                <figure class="post-hero">
                    <img
                        src={heroImage}
                        alt=""
                        width={1280}
                        height={720}
                        loading="eager"
                        transition:name={slug ? `hero-${slug}` : undefined}
                    />
                </figure>
            )}

            <div class="prose">
                <slot />
            </div>

            <footer class="post-footer">
                <div class="share-row">
                    <span class="share-label">{copy.share}</span>
                    <div class="share-actions">
                        <a
                            class="share-btn"
                            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(shareUrl)}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={copy.shareLinks.twitter}
                        >
                            <IconX />
                        </a>
                        <a
                            class="share-btn"
                            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            aria-label={copy.shareLinks.linkedin}
                        >
                            <IconLinkedin />
                        </a>
                        <button
                            type="button"
                            class="share-btn share-btn--copy"
                            data-copy-url={shareUrl}
                            aria-label={copy.shareLinks.copy}
                        >
                            <IconCopy />
                        </button>
                    </div>
                </div>
            </footer>
        </article>

        {
            related.length > 0 && (
                <section class="related" aria-labelledby="related-title">
                    <h2 id="related-title" class="related__title">{copy.relatedTitle}</h2>
                    <ul class="related__list" role="list">
                        {related.map((post) => (
                            <li class="related__item">
                                <a href={`/${lang}/blog/${post.slug.split("/").slice(1).join("/")}`} class="related__link">
                                    {post.heroImage && (
                                        <div class="related__media">
                                            <img src={post.heroImage} alt="" loading="lazy" />
                                        </div>
                                    )}
                                    <div class="related__content">
                                        <h3>{post.title}</h3>
                                        {post.description && <p>{post.description}</p>}
                                        <span class="related__meta">
                                            <span>{post.author}</span>
                                            <span aria-hidden="true">·</span>
                                            <FormattedDate date={post.pubDate} lang={lang} />
                                        </span>
                                    </div>
                                </a>
                            </li>
                        ))}
                    </ul>
                </section>
            )
        }
    </main>
</Layout>

<script>
    const copyBtn = document.querySelector<HTMLButtonElement>(".share-btn--copy");
    if (copyBtn) {
        copyBtn.addEventListener("click", async () => {
            const url = copyBtn.dataset.copyUrl;
            if (!url) return;
            try {
                await navigator.clipboard.writeText(url);
                const original = copyBtn.getAttribute("aria-label") ?? "";
                const lang = document.documentElement.lang;
                const label = lang === "en" ? "Link copied!" : "¡Enlace copiado!";
                copyBtn.setAttribute("aria-label", label);
                copyBtn.classList.add("is-copied");
                window.setTimeout(() => {
                    copyBtn.setAttribute("aria-label", original);
                    copyBtn.classList.remove("is-copied");
                }, 1800);
            } catch {
                // Fallback silently if clipboard is unavailable
            }
        });
    }
</script>

<style>
    .blog-post {
        width: min(900px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.5rem 0 4rem;
        display: grid;
        gap: 2rem;
        box-sizing: border-box;
        min-width: 0;
    }

    .blog-post__nav {
        display: flex;
        align-items: center;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        text-decoration: none;
        color: rgba(23, 30, 48, 0.7);
        font-size: 0.85rem;
        font-weight: 500;
        padding: 0.4rem 0.7rem 0.4rem 0.55rem;
        border-radius: 999px;
        transition: all 200ms ease;
        border: 1px solid transparent;
    }

    .back-link:hover {
        color: rgba(20, 30, 58, 0.95);
        background: rgba(73, 109, 244, 0.08);
        border-color: rgba(73, 109, 244, 0.25);
    }

    .back-link svg {
        transition: transform 200ms ease;
    }

    .back-link:hover svg {
        transform: translateX(-2px);
    }

    .post-article {
        display: grid;
        gap: 1.5rem;
        min-width: 0;
        width: 100%;
    }

    .post-header {
        display: grid;
        gap: 0.85rem;
        min-width: 0;
        width: 100%;
    }

    .post-tags-inline {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .post-tag-inline {
        display: inline-block;
        padding: 0.3rem 0.65rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        text-decoration: none;
        background: rgba(73, 109, 244, 0.1);
        color: var(--color-blue-700, #202ee2);
        border: 1px solid rgba(73, 109, 244, 0.18);
        transition: all 180ms ease;
    }

    .post-tag-inline:hover {
        background: rgba(73, 109, 244, 0.18);
    }

    .post-title {
        margin: 0;
        font-size: clamp(1.85rem, 4.6vw, 3rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        text-wrap: balance;
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .post-lede {
        margin: 0;
        font-size: clamp(1rem, 1.7vw, 1.2rem);
        line-height: 1.55;
        color: rgba(23, 30, 48, 0.7);
        text-wrap: pretty;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .post-meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem 1.5rem;
        align-items: flex-start;
        padding: 1rem 0;
        border-top: 1px solid rgba(95, 114, 166, 0.18);
        border-bottom: 1px solid rgba(95, 114, 166, 0.18);
        min-width: 0;
        width: 100%;
    }

    .post-author {
        display: flex;
        align-items: center;
        gap: 0.65rem;
    }

    .avatar-fallback {
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 999px;
        display: grid;
        place-items: center;
        font-size: 0.85rem;
        font-weight: 700;
        color: #eaf0ff;
        background: linear-gradient(130deg, #2f56f0, #6282ff);
        border: 1px solid rgba(174, 193, 255, 0.4);
        flex: 0 0 auto;
    }

    .meta-block {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.1rem;
        min-width: 0;
    }

    .meta-block--reading-time {
        justify-content: flex-end;
        flex-direction: row;
        align-items: center;
        gap: 0.4rem;
    }

    .meta-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(23, 30, 48, 0.5);
        font-weight: 600;
    }

    .meta-value {
        font-size: 0.88rem;
        font-weight: 500;
        color: rgba(20, 30, 58, 0.9);
        line-height: 1.3;
    }

    .meta-value--reading-time {
        font-size: 0.88rem;
    }

    .meta-reading-icon {
        width: 0.95rem;
        height: 0.95rem;
        color: rgba(23, 30, 48, 0.5);
        flex: 0 0 auto;
    }

    .post-updated {
        margin: 0;
        font-size: 0.8rem;
        font-style: italic;
        color: rgba(23, 30, 48, 0.6);
    }

    .post-hero {
        margin: 0;
        border-radius: 1.1rem;
        overflow: hidden;
        background: linear-gradient(135deg, #2f56f0, #6282ff);
        box-shadow: 0 18px 40px rgba(32, 56, 120, 0.18);
        max-width: 100%;
    }

    .post-hero img {
        display: block;
        width: 100%;
        height: auto;
        max-width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
    }

    @media (max-width: 480px) {
        .post-hero {
            border-radius: 0.75rem;
        }
    }

    .prose {
        font-size: 1.05rem;
        line-height: 1.78;
        color: rgba(20, 30, 58, 0.95);
        text-wrap: pretty;
        word-break: break-word;
        overflow-wrap: break-word;
    }

    .prose :global(p) {
        margin: 0 0 1.4em;
    }

    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4) {
        margin: 2.4em 0 0.8em;
        line-height: 1.2;
        text-wrap: balance;
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .prose :global(h2) {
        font-size: clamp(1.5rem, 3vw, 2rem);
        letter-spacing: -0.01em;
    }

    .prose :global(h3) {
        font-size: clamp(1.25rem, 2.4vw, 1.6rem);
    }

    .prose :global(h4) {
        font-size: clamp(1.1rem, 2vw, 1.3rem);
    }

    .prose :global(a) {
        color: var(--color-blue-700, #202ee2);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        transition: color 180ms ease;
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .prose :global(a:hover) {
        color: var(--color-blue-500, #4c6aff);
    }

    .prose :global(blockquote) {
        margin: 1.5em 0;
        padding: 0.5em 0 0.5em 1.2em;
        border-left: 3px solid var(--color-blue-500, #4c6aff);
        font-size: 1.05em;
        color: rgba(20, 30, 58, 0.85);
        font-style: italic;
    }

    .prose :global(code) {
        font-size: 0.92em;
        padding: 0.15em 0.4em;
        background: rgba(95, 114, 166, 0.12);
        border-radius: 4px;
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .prose :global(pre) {
        padding: 1.2em 1.4em;
        border-radius: 12px;
        background: rgba(15, 20, 35, 0.92);
        color: #e8eef9;
        overflow-x: auto;
        font-size: 0.88em;
        line-height: 1.6;
        max-width: 100%;
        box-sizing: border-box;
    }

    .prose :global(pre code) {
        background: transparent;
        padding: 0;
        color: inherit;
        word-break: normal;
        white-space: pre;
    }

    .prose :global(img),
    .prose :global(iframe),
    .prose :global(video) {
        display: block;
        width: 100%;
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        margin: 1.5em auto;
        box-sizing: border-box;
    }

    .prose :global(iframe) {
        aspect-ratio: 16 / 9;
        border: 0;
    }

    .prose :global(ul),
    .prose :global(ol) {
        margin: 0 0 1.4em;
        padding-left: 1.5em;
    }

    .prose :global(li) {
        margin-bottom: 0.4em;
    }

    .prose :global(hr) {
        border: none;
        border-top: 1px solid rgba(95, 114, 166, 0.2);
        margin: 2.5em 0;
    }

    .prose :global(figure) {
        margin: 1.5em 0;
    }

    .prose :global(figure figcaption) {
        text-align: center;
        font-size: 0.85em;
        color: rgba(23, 30, 48, 0.6);
        margin-top: 0.5em;
    }

    .post-footer {
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(95, 114, 166, 0.18);
    }

    .share-row {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        flex-wrap: wrap;
    }

    .share-label {
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(23, 30, 48, 0.55);
        font-weight: 600;
    }

    .share-actions {
        display: flex;
        gap: 0.5rem;
    }

    .share-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        border-radius: 999px;
        border: 1px solid rgba(95, 114, 166, 0.3);
        background: transparent;
        color: rgba(23, 30, 48, 0.8);
        text-decoration: none;
        cursor: pointer;
        transition: all 200ms ease;
        font: inherit;
    }

    .share-btn:hover {
        background: linear-gradient(120deg, #1f34f3, #4c6aff);
        color: #ffffff;
        border-color: transparent;
        transform: translateY(-2px);
    }

    .share-btn.is-copied {
        background: #16a34a;
        color: #ffffff;
        border-color: transparent;
    }

    .related {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(95, 114, 166, 0.18);
        display: grid;
        gap: 1.2rem;
    }

    .related__title {
        margin: 0;
        font-size: clamp(1.35rem, 2.6vw, 1.7rem);
        letter-spacing: -0.01em;
    }

    .related__list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .related__item {
        display: contents;
    }

    .related__link {
        display: grid;
        gap: 0.75rem;
        padding: 0.85rem;
        border: 1px solid rgba(95, 114, 166, 0.18);
        border-radius: 1rem;
        text-decoration: none;
        color: inherit;
        background: rgba(255, 255, 255, 0.4);
        transition: all 200ms ease;
        min-width: 0;
        width: 100%;
    }

    .related__content {
        min-width: 0;
        width: 100%;
    }

    .related__link:hover {
        border-color: rgba(73, 109, 244, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(32, 56, 120, 0.12);
    }

    .related__media {
        aspect-ratio: 16 / 9;
        border-radius: 0.65rem;
        overflow: hidden;
        background: linear-gradient(135deg, #2f56f0, #6282ff);
    }

    .related__media img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 400ms ease;
    }

    .related__link:hover .related__media img {
        transform: scale(1.05);
    }

    .related__content {
        display: grid;
        gap: 0.4rem;
    }

    .related__content h3 {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.3;
        color: rgba(20, 30, 58, 0.95);
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .related__content p {
        margin: 0;
        font-size: 0.8rem;
        color: rgba(23, 30, 48, 0.65);
        line-height: 1.45;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .related__meta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.72rem;
        color: rgba(23, 30, 48, 0.55);
    }

    :global(html.dark) .post-title,
    :global(html.dark) .post-lede,
    :global(html.dark) .prose {
        color: rgba(229, 236, 255, 0.92);
    }

    :global(html.dark) .post-lede,
    :global(html.dark) .post-updated {
        color: rgba(229, 236, 255, 0.6);
    }

    :global(html.dark) .post-meta-row {
        border-color: rgba(160, 178, 235, 0.2);
    }

    :global(html.dark) .meta-value {
        color: rgba(235, 241, 255, 0.95);
    }

    :global(html.dark) .meta-reading-icon {
        color: rgba(229, 236, 255, 0.55);
    }

    :global(html.dark) .post-footer {
        border-top-color: rgba(160, 178, 235, 0.2);
    }

    :global(html.dark) .related {
        border-top-color: rgba(160, 178, 235, 0.2);
    }

    :global(html.dark) .related__link {
        background: rgba(15, 20, 35, 0.5);
        border-color: rgba(94, 120, 214, 0.28);
    }

    :global(html.dark) .related__content h3 {
        color: rgba(235, 241, 255, 0.95);
    }

    :global(html.dark) .related__content p {
        color: rgba(229, 236, 255, 0.65);
    }

    :global(html.dark) .related__meta {
        color: rgba(229, 236, 255, 0.55);
    }

    :global(html.dark) .prose :global(blockquote) {
        color: rgba(229, 236, 255, 0.85);
    }

    :global(html.dark) .prose :global(code) {
        background: rgba(160, 178, 235, 0.16);
    }

    :global(html.dark) .share-btn {
        color: rgba(229, 236, 255, 0.85);
        border-color: rgba(160, 178, 235, 0.25);
    }

    :global(html.dark) .back-link {
        color: rgba(229, 236, 255, 0.75);
    }

    :global(html.dark) .back-link:hover {
        color: #ffffff;
        background: rgba(95, 126, 252, 0.15);
    }

    @media (max-width: 820px) {
        .related__list {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 720px) {
        .blog-post {
            width: min(900px, calc(100% - 1.6rem));
            padding: 1rem 0 3rem;
            overflow-x: hidden;
        }

        .post-meta-row {
            gap: 0.85rem 1.25rem;
        }

        .prose {
            font-size: 1rem;
        }

        .prose :global(h2) {
            font-size: 1.4rem;
        }

        .prose :global(h3) {
            font-size: 1.2rem;
        }
    }

    @media (max-width: 640px) {
        .post-article,
        .post-header,
        .post-footer,
        .related,
        .prose {
            width: 100%;
            min-width: 0;
        }

        .post-title {
            font-size: clamp(1.55rem, 7vw, 2.2rem);
            word-break: break-word;
            overflow-wrap: anywhere;
        }

        .post-lede {
            font-size: clamp(0.92rem, 4vw, 1.05rem);
        }

        .post-meta-row {
            gap: 0.75rem 1rem;
            align-items: flex-start;
        }

        .meta-value {
            font-size: 0.82rem;
        }

        .meta-value--reading-time {
            font-size: 0.82rem;
        }

        .meta-label {
            font-size: 0.64rem;
