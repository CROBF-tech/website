---
interface Props {
    title: string;
    description: string;
    image?: string;
    type?: "website" | "article";
    lang?: "es" | "en";
    publishedTime?: string;
    author?: string;
}

const { title, description, image, type = "website", lang = "es", publishedTime, author } = Astro.props;

import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeIcon from "../components/ThemeIcon.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang={lang}>
    <head>
        <BaseHead title={title} description={description} image={image} type={type} lang={lang} publishedTime={publishedTime} author={author} />
        <slot name="head" />
    </head>
    <body>
        <Header lang={lang} />
        <slot />
        <ThemeIcon />
        <Footer />

        <!-- Magnetic Buttons Effect -->
        <script>
            import "../scripts/magnetic-buttons.ts";
        </script>
    </body>
</html>

